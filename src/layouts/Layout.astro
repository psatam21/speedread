---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { 
  title, 
  description, 
  canonicalUrl = Astro.url.href, 
  ogImage = '/images/og-default.svg',
  noindex = false,
} = Astro.props;

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID as string | undefined;
const adsenseAutoAds = import.meta.env.PUBLIC_ADSENSE_AUTO_ADS !== 'false';
const adsenseVerification = import.meta.env.PUBLIC_ADSENSE_VERIFICATION as string | undefined;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL as string | undefined;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Merriweather only when serif theme selected later; Inter is self-hosted -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
    </noscript>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
    <meta name="theme-color" content="#5b3ee4" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || Astro.url).href} />
    <meta property="og:site_name" content="SpeedRead" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || Astro.url).href} />

    {adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseVerification.startsWith('ca-pub') ? adsenseVerification : adsenseClient} />
    )}
    {adsenseClient && !adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseClient} />
    )}

    <!-- Critical Theme Script: Avoids FOUC -->
    <script is:inline>
      const getStoredTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      };
      
      const getStoredFont = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('font')) {
          return localStorage.getItem('font');
        }
        return 'sans';
      };
      
      const theme = getStoredTheme();
      const font = getStoredFont();
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('data-font', font);
    </script>
    
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Google AdSense (Auto Ads + manual units) -->
    {adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
        data-ad-client={adsenseClient}
        data-ad-frequency-hint={adsenseAutoAds ? '30s' : undefined}
      ></script>
    )}
  </head>
  <body data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="launch-strip">
      <div class="container launch-strip-inner">
        <span>Free reader. No account. Your files stay on your device.</span>
        <a href="/#importer-card">Start reading <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <header class="site-header">
      <div class="container header-container">
        <a href="/" class="logo-link" aria-label="SpeedRead home">
          <div class="logo-container">
            <svg class="logo-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2z" />
            </svg>
            <span class="logo-text">SpeedRead</span>
          </div>
        </a>
        
        <nav class="nav-links" aria-label="Primary">
          <a href="/" class:list={["nav-link", { active: isHome }]}>Reader</a>
          <a href="/how-it-works" class:list={["nav-link", { active: pathname === '/how-it-works' }]}>How it works</a>
          <a href="/rsvp-reader" class:list={["nav-link", { active: pathname === '/rsvp-reader' }]}>RSVP</a>
          <a href="/bionic-reading" class:list={["nav-link", { active: pathname === '/bionic-reading' }]}>Bionic</a>
          <a href="/extension" class:list={["nav-link", { active: pathname === '/extension' }]}>Chrome</a>
          <button class="nav-account" id="account-open" type="button">Sign in</button>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch to dark mode" aria-pressed="false">◐</button>
          <a href="/#pricing" class="nav-cta">Lifetime · $9</a>
        </nav>
      </div>
    </header>

    <dialog class="account-dialog" id="account-dialog" aria-labelledby="account-title">
      <form class="account-card" id="account-form">
        <div class="account-card-head">
          <div>
            <p class="account-kicker">SpeedRead account</p>
            <h2 id="account-title">Keep Premium tied to you.</h2>
          </div>
          <button class="account-close" id="account-close" type="button" aria-label="Close account dialog">×</button>
        </div>
        <p class="account-copy">Sign in to carry Lifetime Premium and reading totals across devices. Your documents still stay in this browser.</p>
        <div class="account-fields" id="account-fields">
          <label>Email<input id="account-email" type="email" autocomplete="email" required /></label>
          <label>Password<input id="account-password" type="password" autocomplete="current-password" minlength="8" required /></label>
        </div>
        <p class="account-status" id="account-status" role="status" aria-live="polite"></p>
        <div class="account-actions" id="account-actions">
          <button class="btn btn-primary" type="submit">Sign in</button>
          <button class="btn btn-secondary" id="account-signup" type="button">Create account</button>
        </div>
        <div class="account-session hidden" id="account-session">
          <div><span>Signed in as</span><strong id="account-identity"></strong></div>
          <div><span>Plan</span><strong id="account-plan">Free</strong></div>
          <button class="btn btn-secondary" id="account-signout" type="button">Sign out</button>
        </div>
      </form>
    </dialog>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <a href="/" class="footer-logo">SpeedRead<span>.</span></a>
          <p>Read the backlog, not the interface. RSVP, bionic reading, OCR and synced speech in one private browser tool.</p>
          <p class="footer-note">© {new Date().getFullYear()} SpeedRead</p>
        </div>
        <div class="footer-group">
          <p>Read</p>
          <a href="/">Speed reader</a>
          <a href="/how-it-works">How it works</a>
          <a href="/rsvp-reader">RSVP reader</a>
          <a href="/bionic-reading">Bionic reading</a>
          <a href="/pdf-to-speech">PDF to speech</a>
        </div>
        <div class="footer-group">
          <p>Capture</p>
          <a href="/extension">Chrome extension</a>
          <a href="/bookmarklet">Bookmarklet</a>
          <a href="/#pricing">Lifetime Premium</a>
        </div>
        <div class="footer-group">
          <p>Company</p>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      const syncThemeToggle = () => {
        const isDark = document.documentElement.dataset.theme === 'dark' || document.documentElement.dataset.theme === 'amoled';
        themeToggle?.setAttribute('aria-pressed', String(isDark));
        themeToggle?.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
      };
      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
        syncThemeToggle();
      });
      syncThemeToggle();
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';

      const accountButton = document.getElementById('account-open');
      const accountDialog = document.getElementById('account-dialog');
      const accountForm = document.getElementById('account-form');
      const accountFields = document.getElementById('account-fields');
      const accountActions = document.getElementById('account-actions');
      const accountSession = document.getElementById('account-session');
      const accountStatus = document.getElementById('account-status');
      const accountIdentity = document.getElementById('account-identity');
      const accountPlan = document.getElementById('account-plan');
      const accountEmail = document.getElementById('account-email');
      const accountPassword = document.getElementById('account-password');
      const url = document.body.dataset.supabaseUrl;
      const key = document.body.dataset.supabaseAnonKey;
      const supabase = url && key ? createClient(url, key) : null;

      (globalThis as any).speedreadSupabase = supabase;

      const setStatus = (message, isError = false) => {
        if (!accountStatus) return;
        accountStatus.textContent = message;
        accountStatus.classList.toggle('is-error', isError);
      };

      const renderAccount = async (session) => {
        const user = session?.user;
        accountFields?.classList.toggle('hidden', Boolean(user));
        accountActions?.classList.toggle('hidden', Boolean(user));
        accountSession?.classList.toggle('hidden', !user);
        if (accountButton) accountButton.textContent = user ? 'Account' : 'Sign in';
        if (!user) {
          setStatus('');
          globalThis.dispatchEvent(new CustomEvent('speedread:account', { detail: { user: null, premium: false } }));
          return;
        }

        if (accountIdentity) accountIdentity.textContent = user.email || 'SpeedRead member';
        const { data } = await supabase
          .from('entitlements')
          .select('status, product_key')
          .eq('user_id', user.id)
          .maybeSingle();
        const premium = data?.status === 'active';
        if (accountPlan) accountPlan.textContent = premium ? 'Lifetime Premium' : 'Free';
        setStatus(premium ? 'Lifetime Premium is active on this account.' : 'Your account is ready. Premium will attach here after purchase.');
        globalThis.dispatchEvent(new CustomEvent('speedread:account', { detail: { user, premium } }));
      };

      accountButton?.addEventListener('click', () => accountDialog?.showModal());
      document.getElementById('account-close')?.addEventListener('click', () => accountDialog?.close());
      accountDialog?.addEventListener('click', (event) => {
        if (event.target === accountDialog) accountDialog.close();
      });

      accountForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!supabase) return setStatus('Account service is not configured yet.', true);
        setStatus('Signing in…');
        const { error } = await supabase.auth.signInWithPassword({
          email: accountEmail?.value.trim() || '',
          password: accountPassword?.value || '',
        });
        if (error) setStatus(error.message, true);
      });

      document.getElementById('account-signup')?.addEventListener('click', async () => {
        if (!supabase) return setStatus('Account service is not configured yet.', true);
        setStatus('Creating your account…');
        const { data, error } = await supabase.auth.signUp({
          email: accountEmail?.value.trim() || '',
          password: accountPassword?.value || '',
        });
        if (error) return setStatus(error.message, true);
        setStatus(data.session ? 'Account created.' : 'Check your email to confirm your account.');
      });

      document.getElementById('account-signout')?.addEventListener('click', async () => {
        if (supabase) {
          await supabase.auth.signOut();
          window.location.reload();
        }
      });

      if (supabase) {
        const { data } = await supabase.auth.getSession();
        await renderAccount(data.session);
        supabase.auth.onAuthStateChange((_event, session) => {
          window.setTimeout(() => renderAccount(session), 0);
        });
      } else if (accountButton) {
        accountButton.title = 'Account service is being configured';
      }
    </script>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        background-color: var(--color-bg-header);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: var(--z-sticky, 50);
      }
      .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 4.25rem;
      }
      .launch-strip {
        background: var(--color-ink);
        color: var(--color-ink-on);
        font-size: 0.75rem;
        font-weight: 600;
      }
      .launch-strip-inner {
        min-height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        text-align: center;
      }
      .launch-strip a { color: var(--color-ink-on); text-decoration: underline; text-underline-offset: 3px; }
      .skip-link {
        position: fixed;
        left: 1rem;
        top: 0.5rem;
        z-index: var(--z-toast);
        padding: 0.5rem 0.75rem;
        background: var(--color-bg-card);
        color: var(--color-text);
        transform: translateY(-150%);
      }
      .skip-link:focus { transform: translateY(0); }
      .logo-link {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-link:hover {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-container {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
      }
      .logo-icon {
        color: var(--color-primary);
        flex-shrink: 0;
      }
      .logo-text {
        color: var(--color-text);
      }
      .nav-links {
        display: flex;
        gap: 0.15rem;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .nav-link {
        font-size: 0.8125rem;
        font-weight: 550;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: background-color 120ms ease, color 120ms ease;
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
      }
      .nav-link:hover {
        color: var(--color-text);
        background-color: var(--color-bg-subtle);
        text-decoration: none;
      }
      .nav-link.active { color: var(--color-text); background: var(--color-primary-muted); }
      .nav-account {
        border: 0;
        background: transparent;
        color: var(--color-text-muted);
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
        font: 550 0.8125rem/1 var(--font-sans);
        cursor: pointer;
      }
      .nav-account:hover { color: var(--color-text); background: var(--color-bg-subtle); }
      .theme-toggle {
        width: 2rem;
        height: 2rem;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        background: var(--color-bg-card);
        color: var(--color-text);
        cursor: pointer;
        font-size: 1rem;
      }
      .nav-cta {
        padding: 0.48rem 0.8rem;
        border-radius: var(--radius-md);
        background: var(--color-primary);
        color: white;
        font-size: 0.8125rem;
        font-weight: 700;
      }
      .nav-cta:hover { background: var(--color-primary-hover); color: white; }

      .account-dialog {
        width: min(92vw, 31rem);
        padding: 0;
        border: 1px solid var(--color-border);
        border-radius: 14px;
        background: var(--color-bg-card);
        color: var(--color-text);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
      }
      .account-dialog::backdrop { background: rgba(0, 0, 0, 0.62); backdrop-filter: blur(3px); }
      .account-card { padding: 1.5rem; }
      .account-card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
      .account-card-head h2 { max-width: 12ch; margin: 0.25rem 0 0; font-size: 2rem; line-height: 1; }
      .account-kicker { margin: 0; color: var(--color-primary); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
      .account-copy { margin: 1rem 0; color: var(--color-text-muted); font-size: 0.86rem; line-height: 1.6; }
      .account-close { width: 2rem; height: 2rem; border: 1px solid var(--color-border); border-radius: 50%; background: transparent; color: var(--color-text); cursor: pointer; font-size: 1.15rem; }
      .account-fields { display: grid; gap: 0.8rem; }
      .account-fields label { display: grid; gap: 0.35rem; color: var(--color-text-muted); font-size: 0.75rem; font-weight: 700; }
      .account-fields input { width: 100%; padding: 0.72rem 0.8rem; border: 1px solid var(--color-border); border-radius: 7px; background: var(--color-bg-subtle); color: var(--color-text); font: inherit; }
      .account-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; margin-top: 1rem; }
      .account-status { min-height: 1.4em; margin: 0.75rem 0 0; color: var(--color-text-muted); font-size: 0.76rem; }
      .account-status.is-error { color: #dc2626; }
      .account-session { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: end; padding-top: 0.5rem; }
      .account-session div span, .account-session div strong { display: block; }
      .account-session div span { color: var(--color-text-muted); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; }
      .account-session div strong { margin-top: 0.25rem; font-size: 0.83rem; overflow-wrap: anywhere; }
      .account-session .btn { grid-column: 1 / -1; }
      
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: clamp(3rem, 8vw, 5rem) 0;
        margin-top: 4rem;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        background-color: var(--color-bg-footer);
      }
      .footer-container {
        display: grid;
        grid-template-columns: minmax(0, 1.8fr) repeat(3, minmax(110px, 1fr));
        align-items: start;
        gap: clamp(2rem, 5vw, 4rem);
        text-align: left;
      }
      .footer-logo { color: var(--color-text); font-size: 1.25rem; font-weight: 800; }
      .footer-logo span { color: var(--color-accent); }
      .footer-brand > p { max-width: 40ch; margin-top: 0.75rem; }
      .footer-note { font-size: 0.75rem; }
      .footer-group { display: flex; flex-direction: column; gap: 0.55rem; }
      .footer-group p { color: var(--color-text); font-weight: 700; margin-bottom: 0.2rem; }
      .footer-group a { color: var(--color-text-muted); }
      .footer-group a:hover { color: var(--color-primary); }
      @media (max-width: 480px) {
        .header-container {
          flex-direction: column;
          height: auto;
          padding: 0.75rem 1rem;
          gap: 0.75rem;
        }
        .nav-links {
          gap: 0.15rem;
          width: 100%;
          justify-content: center;
        }
        .nav-link {
          font-size: 0.75rem;
          padding: 0.35rem 0.45rem;
        }
        .nav-link:nth-child(3), .nav-link:nth-child(4) { display: none; }
        .launch-strip-inner { justify-content: space-between; }
        .launch-strip-inner > span { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
      }
      @media (max-width: 760px) {
        .footer-container { grid-template-columns: 1fr 1fr; }
        .footer-brand { grid-column: 1 / -1; }
      }
    </style>
  </body>
</html>
