---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { 
  title, 
  description, 
  canonicalUrl = Astro.url.href, 
  ogImage = '/images/og-default.svg',
  noindex = false,
} = Astro.props;

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID as string | undefined;
const adsenseAutoAds = import.meta.env.PUBLIC_ADSENSE_AUTO_ADS !== 'false';
const adsenseVerification = import.meta.env.PUBLIC_ADSENSE_VERIFICATION as string | undefined;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL as string | undefined;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Merriweather only when serif theme selected later; Inter is self-hosted -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
    </noscript>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
    <meta name="theme-color" content="#5b3ee4" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || Astro.url).href} />
    <meta property="og:site_name" content="SpeedRead" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || Astro.url).href} />

    {adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseVerification.startsWith('ca-pub') ? adsenseVerification : adsenseClient} />
    )}
    {adsenseClient && !adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseClient} />
    )}

    <!-- Critical Theme Script: Avoids FOUC -->
    <script is:inline>
      const getStoredTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      };
      
      const getStoredFont = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('font')) {
          return localStorage.getItem('font');
        }
        return 'sans';
      };
      
      const theme = getStoredTheme();
      const font = getStoredFont();
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('data-font', font);
    </script>
    
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Google AdSense (Auto Ads + manual units) -->
    {adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
        data-ad-client={adsenseClient}
        data-ad-frequency-hint={adsenseAutoAds ? '30s' : undefined}
      ></script>
    )}
  </head>
  <body data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="launch-strip">
      <div class="container launch-strip-inner">
        <span>Free reader. No account. Your files stay on your device.</span>
        <a href="/#importer-card">Start reading <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <header class="site-header">
      <div class="container header-container">
        <a href="/" class="logo-link" aria-label="SpeedRead home">
          <div class="logo-container">
            <svg class="logo-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2z" />
            </svg>
            <span class="logo-text">SpeedRead</span>
          </div>
        </a>
        
        <nav class="nav-links" aria-label="Primary">
          <a href="/" class:list={["nav-link", { active: isHome }]}>Reader</a>
          <a href="/how-it-works" class:list={["nav-link", { active: pathname === '/how-it-works' }]}>How it works</a>
          <a href="/rsvp-reader" class:list={["nav-link", { active: pathname === '/rsvp-reader' }]}>RSVP</a>
          <a href="/bionic-reading" class:list={["nav-link", { active: pathname === '/bionic-reading' }]}>Bionic</a>
          <a href="/extension" class:list={["nav-link", { active: pathname === '/extension' }]}>Chrome</a>
          <a href="/account" class:list={["nav-link", { active: pathname === '/account' }]}>Account</a>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch to dark mode" aria-pressed="false">◐</button>
          <a href="/#pricing" class="nav-cta">Lifetime · $9</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <a href="/" class="footer-logo">SpeedRead<span>.</span></a>
          <p>Read the backlog, not the interface. RSVP, bionic reading, OCR and synced speech in one private browser tool.</p>
          <p class="footer-note">© {new Date().getFullYear()} SpeedRead</p>
        </div>
        <div class="footer-group">
          <p>Read</p>
          <a href="/">Speed reader</a>
          <a href="/how-it-works">How it works</a>
          <a href="/rsvp-reader">RSVP reader</a>
          <a href="/bionic-reading">Bionic reading</a>
          <a href="/pdf-to-speech">PDF to speech</a>
        </div>
        <div class="footer-group">
          <p>Capture</p>
          <a href="/extension">Chrome extension</a>
          <a href="/bookmarklet">Bookmarklet</a>
          <a href="/#pricing">Lifetime Premium</a>
        </div>
        <div class="footer-group">
          <p>Company</p>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      const syncThemeToggle = () => {
        const isDark = document.documentElement.dataset.theme === 'dark' || document.documentElement.dataset.theme === 'amoled';
        themeToggle?.setAttribute('aria-pressed', String(isDark));
        themeToggle?.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
      };
      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
        syncThemeToggle();
      });
      syncThemeToggle();
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';

      const url = document.body.dataset.supabaseUrl;
      const key = document.body.dataset.supabaseAnonKey;
      const supabase = url && key ? createClient(url, key) : null;

      (globalThis as any).speedreadSupabase = supabase;

      const renderAccount = async (session) => {
        const user = session?.user;
        if (!user) {
          globalThis.dispatchEvent(new CustomEvent('speedread:account', { detail: { user: null, premium: false } }));
          return;
        }

        const { data } = await supabase
          .from('entitlements')
          .select('status, product_key')
          .eq('user_id', user.id)
          .maybeSingle();
        const premium = data?.status === 'active';
        globalThis.dispatchEvent(new CustomEvent('speedread:account', { detail: { user, premium } }));
      };

      if (supabase) {
        const { data } = await supabase.auth.getSession();
        await renderAccount(data.session);
        supabase.auth.onAuthStateChange((_event, session) => {
          window.setTimeout(() => renderAccount(session), 0);
        });
      }
    </script>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        background-color: var(--color-bg-header);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: var(--z-sticky, 50);
      }
      .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 4.25rem;
      }
      .launch-strip {
        background: var(--color-ink);
        color: var(--color-ink-on);
        font-size: 0.75rem;
        font-weight: 600;
      }
      .launch-strip-inner {
        min-height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        text-align: center;
      }
      .launch-strip a { color: var(--color-ink-on); text-decoration: underline; text-underline-offset: 3px; }
      .skip-link {
        position: fixed;
        left: 1rem;
        top: 0.5rem;
        z-index: var(--z-toast);
        padding: 0.5rem 0.75rem;
        background: var(--color-bg-card);
        color: var(--color-text);
        transform: translateY(-150%);
      }
      .skip-link:focus { transform: translateY(0); }
      .logo-link {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-link:hover {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-container {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
      }
      .logo-icon {
        color: var(--color-primary);
        flex-shrink: 0;
      }
      .logo-text {
        color: var(--color-text);
      }
      .nav-links {
        display: flex;
        gap: 0.15rem;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .nav-link {
        font-size: 0.8125rem;
        font-weight: 550;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: background-color 120ms ease, color 120ms ease;
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
      }
      .nav-link:hover {
        color: var(--color-text);
        background-color: var(--color-bg-subtle);
        text-decoration: none;
      }
      .nav-link.active { color: var(--color-text); background: var(--color-primary-muted); }
      .theme-toggle {
        width: 2rem;
        height: 2rem;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        background: var(--color-bg-card);
        color: var(--color-text);
        cursor: pointer;
        font-size: 1rem;
      }
      .nav-cta {
        padding: 0.48rem 0.8rem;
        border-radius: var(--radius-md);
        background: var(--color-primary);
        color: white;
        font-size: 0.8125rem;
        font-weight: 700;
      }
      .nav-cta:hover { background: var(--color-primary-hover); color: white; }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: clamp(3rem, 8vw, 5rem) 0;
        margin-top: 4rem;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        background-color: var(--color-bg-footer);
      }
      .footer-container {
        display: grid;
        grid-template-columns: minmax(0, 1.8fr) repeat(3, minmax(110px, 1fr));
        align-items: start;
        gap: clamp(2rem, 5vw, 4rem);
        text-align: left;
      }
      .footer-logo { color: var(--color-text); font-size: 1.25rem; font-weight: 800; }
      .footer-logo span { color: var(--color-accent); }
      .footer-brand > p { max-width: 40ch; margin-top: 0.75rem; }
      .footer-note { font-size: 0.75rem; }
      .footer-group { display: flex; flex-direction: column; gap: 0.55rem; }
      .footer-group p { color: var(--color-text); font-weight: 700; margin-bottom: 0.2rem; }
      .footer-group a { color: var(--color-text-muted); }
      .footer-group a:hover { color: var(--color-primary); }
      @media (max-width: 480px) {
        .header-container {
          flex-direction: column;
          height: auto;
          padding: 0.75rem 1rem;
          gap: 0.75rem;
        }
        .nav-links {
          gap: 0.15rem;
          width: 100%;
          justify-content: center;
        }
        .nav-link {
          font-size: 0.75rem;
          padding: 0.35rem 0.45rem;
        }
        .nav-link:nth-child(3), .nav-link:nth-child(4) { display: none; }
        .launch-strip-inner { justify-content: space-between; }
        .launch-strip-inner > span { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
      }
      @media (max-width: 760px) {
        .footer-container { grid-template-columns: 1fr 1fr; }
        .footer-brand { grid-column: 1 / -1; }
      }
    </style>
  </body>
</html>
