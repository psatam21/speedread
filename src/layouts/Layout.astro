---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { 
  title, 
  description, 
  canonicalUrl = Astro.url.href, 
  ogImage = '/images/og-default.svg' 
} = Astro.props;

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID as string | undefined;
const adsenseAutoAds = import.meta.env.PUBLIC_ADSENSE_AUTO_ADS !== 'false';
const adsenseVerification = import.meta.env.PUBLIC_ADSENSE_VERIFICATION as string | undefined;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Merriweather only when serif theme selected later; Inter is self-hosted -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#5e6ad2" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || Astro.url).href} />
    <meta property="og:site_name" content="SpeedRead" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || Astro.url).href} />

    {adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseVerification.startsWith('ca-pub') ? adsenseVerification : adsenseClient} />
    )}
    {adsenseClient && !adsenseVerification && (
      <meta name="google-adsense-account" content={adsenseClient} />
    )}

    <!-- Critical Theme Script: Avoids FOUC -->
    <script is:inline>
      const getStoredTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };
      
      const getStoredFont = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('font')) {
          return localStorage.getItem('font');
        }
        return 'sans';
      };
      
      const theme = getStoredTheme();
      const font = getStoredFont();
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('data-font', font);
    </script>
    
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Google AdSense (Auto Ads + manual units) -->
    {adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
        data-ad-client={adsenseClient}
        data-ad-frequency-hint={adsenseAutoAds ? '30s' : undefined}
      ></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container header-container">
        <a href="/" class="logo-link">
          <div class="logo-container">
            <span class="logo-icon">⚡</span>
            <span class="logo-text">SpeedRead</span>
          </div>
        </a>
        
        <nav class="nav-links" aria-label="Primary">
          <a href="/rsvp-reader" class="nav-link">RSVP</a>
          <a href="/bionic-reading" class="nav-link">Bionic</a>
          <a href="/extension" class="nav-link">Extension</a>
          <a href="/bookmarklet" class="nav-link">Bookmarklet</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/contact" class="nav-link">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <p>© {new Date().getFullYear()} SpeedRead. Free online speed reader — RSVP, bionic reading, PDF to speech.</p>
          <p class="footer-tools">
            Tools:
            <a href="/">Speed reader</a> ·
            <a href="/extension">Chrome extension</a> ·
            <a href="/rsvp-reader">RSVP</a> ·
            <a href="/bionic-reading">Bionic</a> ·
            <a href="/pdf-to-speech">PDF to speech</a>
          </p>
        </div>
        <div class="footer-links">
          <a href="/privacy">Privacy Policy</a>
          <span>•</span>
          <a href="/terms">Terms of Service</a>
          <span>•</span>
          <a href="/about">About Us</a>
          <span>•</span>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        background-color: var(--color-bg-header);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: var(--z-sticky, 50);
      }
      .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 3.75rem;
      }
      .logo-link {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-link:hover {
        text-decoration: none;
        color: var(--color-text);
      }
      .logo-container {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
      }
      .logo-icon {
        font-size: 1.2rem;
        color: var(--color-primary);
      }
      .logo-text {
        color: var(--color-text);
      }
      .nav-links {
        display: flex;
        gap: 0.15rem;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .nav-link {
        font-size: 0.8125rem;
        font-weight: 550;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: background-color 120ms ease, color 120ms ease;
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
      }
      .nav-link:hover {
        color: var(--color-text);
        background-color: var(--color-bg-subtle);
        text-decoration: none;
      }
      
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-top: 4rem;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        background-color: var(--color-bg-footer);
      }
      .footer-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
      }
      .footer-tools {
        margin-top: 0.5rem;
        font-size: 0.8rem;
      }
      .footer-tools a {
        color: var(--color-text-muted);
      }
      @media (min-width: 768px) {
        .footer-container {
          flex-direction: row;
          justify-content: space-between;
          text-align: left;
        }
      }
      @media (max-width: 480px) {
        .header-container {
          flex-direction: column;
          height: auto;
          padding: 1.25rem 1rem;
          gap: 0.75rem;
        }
        .nav-links {
          gap: 0.15rem;
          width: 100%;
          justify-content: center;
        }
        .nav-link {
          font-size: 0.75rem;
          padding: 0.35rem 0.45rem;
        }
      }
      .footer-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-links a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 150ms ease;
      }
      .footer-links a:hover {
        color: var(--color-primary);
        text-decoration: none;
      }
    </style>
  </body>
</html>
