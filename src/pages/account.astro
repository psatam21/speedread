---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Your Account | SpeedRead"
  description="Sign in to manage your SpeedRead account, reading totals, and Lifetime Premium access."
  noindex={true}
>
  <section class="account-page" aria-labelledby="account-page-title">
    <div class="container account-shell">
      <div class="account-intro">
        <p class="account-kicker">Your SpeedRead account</p>
        <h1 id="account-page-title">Your reading progress, wherever you open it.</h1>
        <p class="account-lede">Sign in to keep Lifetime Premium and your reading totals connected across devices. The documents you import stay in your browser.</p>

        <div class="account-promises" aria-label="Account benefits">
          <article>
            <span>01</span>
            <div><strong>Private by default</strong><p>Imported documents are processed locally and are not added to your account.</p></div>
          </article>
          <article>
            <span>02</span>
            <div><strong>One permanent purchase</strong><p>Lifetime Premium attaches to the account used at checkout.</p></div>
          </article>
          <article>
            <span>03</span>
            <div><strong>Progress that travels</strong><p>Words read and time saved can follow you between signed-in devices.</p></div>
          </article>
        </div>
      </div>

      <div class="account-panel">
        <div class="account-panel-head">
          <span class="account-signal" aria-hidden="true"></span>
          <span>Secure account access</span>
        </div>

        <form id="account-page-form" class="account-form">
          <div id="account-signed-out">
            <h2>Sign in to continue</h2>
            <p>Use the same email you use for your Premium purchase.</p>

            <label for="account-email">Email address</label>
            <input id="account-email" type="email" autocomplete="email" placeholder="you@example.com" required />

            <label for="account-password">Password</label>
            <input id="account-password" type="password" autocomplete="current-password" minlength="8" placeholder="At least 8 characters" required />

            <p class="account-status" id="account-status" role="status" aria-live="polite"></p>
            <button class="btn btn-primary account-submit" type="submit">Sign in</button>
            <button class="account-create" id="account-signup" type="button">New here? Create an account</button>
          </div>

          <div class="account-session hidden" id="account-signed-in">
            <p class="account-session-label">Signed in</p>
            <h2 id="account-identity">SpeedRead member</h2>
            <div class="account-plan-row">
              <span>Current plan</span>
              <strong id="account-plan">Free</strong>
            </div>
            <p id="account-session-copy">Your account is ready. Premium will attach here after purchase.</p>
            <a class="btn btn-primary" id="account-upgrade" href="/#pricing">View Lifetime Premium</a>
            <a class="btn btn-secondary" href="/">Open the reader</a>
            <button class="account-create" id="account-signout" type="button">Sign out</button>
          </div>
        </form>

        <p class="account-footnote">Authentication is handled by Supabase. SpeedRead never sees your password.</p>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('account-page-form') as HTMLFormElement | null;
    const signedOut = document.getElementById('account-signed-out');
    const signedIn = document.getElementById('account-signed-in');
    const email = document.getElementById('account-email') as HTMLInputElement | null;
    const password = document.getElementById('account-password') as HTMLInputElement | null;
    const status = document.getElementById('account-status');
    const identity = document.getElementById('account-identity');
    const plan = document.getElementById('account-plan');
    const sessionCopy = document.getElementById('account-session-copy');
    const upgrade = document.getElementById('account-upgrade');
    let redirectHandled = false;

    const setStatus = (message: string, isError = false) => {
      if (!status) return;
      status.textContent = message;
      status.classList.toggle('is-error', isError);
    };

    const renderAccount = ({ user, premium }) => {
      signedOut?.classList.toggle('hidden', Boolean(user));
      signedIn?.classList.toggle('hidden', !user);
      if (!user) return;

      if (identity) identity.textContent = user.email || 'SpeedRead member';
      if (plan) plan.textContent = premium ? 'Lifetime Premium' : 'Free';
      if (sessionCopy) sessionCopy.textContent = premium
        ? 'Lifetime Premium is active on this account.'
        : 'Your account is ready. Premium will attach here after purchase.';
      upgrade?.classList.toggle('hidden', Boolean(premium));

      const next = new URLSearchParams(window.location.search).get('next');
      if (!redirectHandled && next?.startsWith('/') && !next.startsWith('//')) {
        redirectHandled = true;
        window.location.assign(next);
      }
    };

    globalThis.addEventListener('speedread:account', (event) => {
      renderAccount((event as CustomEvent).detail);
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const supabase = (globalThis as any).speedreadSupabase;
      if (!supabase) return setStatus('Account service is not configured yet.', true);
      setStatus('Signing in...');
      const { error } = await supabase.auth.signInWithPassword({
        email: email?.value.trim() || '',
        password: password?.value || '',
      });
      if (error) setStatus(error.message, true);
    });

    document.getElementById('account-signup')?.addEventListener('click', async () => {
      if (!form?.reportValidity()) return;
      const supabase = (globalThis as any).speedreadSupabase;
      if (!supabase) return setStatus('Account service is not configured yet.', true);
      setStatus('Creating your account...');
      const { data, error } = await supabase.auth.signUp({
        email: email?.value.trim() || '',
        password: password?.value || '',
      });
      if (error) return setStatus(error.message, true);
      setStatus(data.session ? 'Account created.' : 'Check your email to confirm your account.');
    });

    document.getElementById('account-signout')?.addEventListener('click', async () => {
      const supabase = (globalThis as any).speedreadSupabase;
      if (!supabase) return;
      await supabase.auth.signOut();
      window.location.reload();
    });
  </script>

  <style>
    .account-page {
      min-height: 72vh;
      padding: clamp(3.5rem, 9vw, 7rem) 0;
      border-bottom: 1px solid var(--color-border);
    }
    .account-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.72fr);
      gap: clamp(3rem, 9vw, 8rem);
      align-items: start;
    }
    .account-kicker {
      margin: 0 0 1rem;
      color: var(--color-primary);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .account-intro h1 {
      max-width: 12ch;
      margin: 0;
      font-size: clamp(3rem, 6vw, 5.8rem);
      line-height: 0.94;
      letter-spacing: -0.065em;
    }
    .account-lede {
      max-width: 37rem;
      margin: 1.5rem 0 2.5rem;
      color: var(--color-text-muted);
      font-size: clamp(1rem, 1.7vw, 1.2rem);
      line-height: 1.65;
    }
    .account-promises { border-top: 1px solid var(--color-border); }
    .account-promises article {
      display: grid;
      grid-template-columns: 2rem 1fr;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .account-promises article > span { color: var(--color-primary); font-size: 0.7rem; font-weight: 800; }
    .account-promises strong { display: block; font-size: 0.9rem; }
    .account-promises p { margin: 0.25rem 0 0; color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.5; }
    .account-panel {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-bg-card);
      box-shadow: 0 16px 44px rgba(15, 23, 42, 0.08);
      overflow: hidden;
    }
    .account-panel-head {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.8rem 1rem;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-text-muted);
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .account-signal { width: 0.55rem; height: 0.55rem; border-radius: 50%; background: var(--color-primary); box-shadow: 0 0 0 4px var(--color-primary-muted); }
    .account-form { padding: clamp(1.5rem, 4vw, 2.25rem); }
    .account-form h2 { margin: 0; font-size: clamp(1.6rem, 3vw, 2.2rem); letter-spacing: -0.035em; overflow-wrap: anywhere; }
    .account-form h2 + p { margin: 0.55rem 0 1.6rem; color: var(--color-text-muted); font-size: 0.84rem; line-height: 1.55; }
    .account-form label { display: block; margin: 1rem 0 0.4rem; color: var(--color-text-muted); font-size: 0.74rem; font-weight: 750; }
    .account-form input {
      width: 100%;
      padding: 0.82rem 0.9rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-bg-subtle);
      color: var(--color-text);
      font: inherit;
    }
    .account-form input:focus { border-color: var(--color-primary); outline: 3px solid var(--color-primary-muted); }
    .account-status { min-height: 1.3em; margin: 0.8rem 0; color: var(--color-text-muted); font-size: 0.76rem; }
    .account-status.is-error { color: var(--color-danger); }
    .account-submit { width: 100%; }
    .account-create { display: block; margin: 1rem auto 0; padding: 0; border: 0; background: transparent; color: var(--color-text-muted); font: 700 0.76rem/1.4 var(--font-sans); cursor: pointer; text-decoration: underline; text-underline-offset: 0.2rem; }
    .account-create:hover { color: var(--color-primary); }
    .account-session { display: grid; gap: 0.75rem; }
    .account-session-label { margin: 0; color: var(--color-success); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
    .account-plan-row { display: flex; justify-content: space-between; gap: 1rem; margin: 1rem 0 0; padding: 1rem 0; border-block: 1px solid var(--color-border); font-size: 0.82rem; }
    .account-plan-row span, .account-session > p:not(.account-session-label) { color: var(--color-text-muted); }
    .account-session > p:not(.account-session-label) { margin: 0 0 0.5rem; font-size: 0.82rem; line-height: 1.55; }
    .account-footnote { margin: 0; padding: 0.85rem 1rem; border-top: 1px solid var(--color-border); background: var(--color-bg-subtle); color: var(--color-text-subtle); font-size: 0.68rem; line-height: 1.5; text-align: center; }
    @media (max-width: 820px) {
      .account-shell { grid-template-columns: 1fr; gap: 2.5rem; }
      .account-intro h1 { max-width: 11ch; }
    }
  </style>
</Layout>
