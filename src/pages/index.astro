---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';

const pageTitle = "Online Speed Reader — RSVP, Bionic & TTS | SpeedRead";
const pageDescription = "Free online speed reader with RSVP, bionic text, PDF and EPUB import, image OCR, and synced speech. No install or account required.";
const siteUrl = new URL('/', Astro.site || Astro.url).href;
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'SpeedRead',
  url: siteUrl,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript',
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: '0',
    highPrice: '9.00',
    priceCurrency: 'USD',
    offerCount: '2',
  },
  description: 'Free online speed reader with RSVP, bionic reading, PDF and EPUB import, and text-to-speech.',
};
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Top App Section: Interactive Reader Workspace -->
  <section class="app-section">
    <div class="container app-workspace">

      <!-- Hero -->
      <header class="hero">
        <div class="hero-copy">
          <h1>Finish the backlog.<br />Keep the meaning.</h1>
          <p class="hero-sub">
            RSVP speed reading that helps you read faster<br />while understanding more.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#importer-card">Try it with your text</a>
            <button class="hero-demo-link" id="btn-hero-demo" type="button">Try a sample text</button>
          </div>
          <ul class="hero-trust" aria-label="Product benefits">
            <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v5c0 4.5 3 8 7 10 4-2 7-5.5 7-10V6l-7-3Zm0 6v4m0 3h.01" /></svg><span><strong>100% private</strong><small>Your text stays<br />in your browser.</small></span></li>
            <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m13 2-9 12h7l-1 8 10-13h-7l0-7Z" /></svg><span><strong>Up to 3x faster</strong><small>Read more in less time<br />without losing meaning.</small></span></li>
            <li><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="3" /><path d="m12 4 1.4 2.6L16 8l-2.6 1.4L12 12l-1.4-2.6L8 8l2.6-1.4L12 4Z" /></svg><span><strong>Better focus</strong><small>Fewer distractions.<br />More comprehension.</small></span></li>
          </ul>
        </div>
        <div class="hero-reader" aria-label="Animated RSVP reading preview">
          <div class="hero-reader-top"><strong>RSVP Reader</strong><div class="hero-reader-tools"><button id="hero-play" type="button" aria-pressed="false" aria-label="Pause RSVP preview">Ⅱ</button></div></div>
          <div class="hero-preview-stage">
            <p><i></i>Optimal recognition point</p>
            <div class="hero-word" aria-live="off"><span id="hero-word-left">cre</span><strong id="hero-word-orp">a</strong><span id="hero-word-right">te</span></div>
          </div>
          <div class="hero-demo-controls">
            <div class="hero-speed-control"><span>WPM<strong id="hero-wpm-output">350</strong></span><div><input id="hero-wpm-slider" aria-label="Words per minute" type="range" min="100" max="600" step="10" value="350" /><div class="hero-wpm-ticks"><span>100</span><span>200</span><span>300</span><span>400</span><span>500</span><span>600</span></div></div></div>
          </div>
          <div class="hero-reader-bottom"><strong>How you compare</strong><div><span>Typical reading<b>~240 <small>WPM</small></b></span><i>→</i><span class="hero-rsvp-pace">RSVP with SpeedRead<b>350 <small>WPM</small></b></span></div><p>Based on average adult silent reading speed of 200–280 WPM.</p></div>
        </div>
      </header>

      <section class="hero-import-rail" aria-labelledby="hero-import-title">
        <div class="hero-import-heading"><div><h2 id="hero-import-title">Bring in text</h2><p>Choose a source, then start reading in seconds.</p></div></div>
        <div class="hero-import-options">
          <button class="hero-import-option" type="button" data-open-tab="paste"><strong>Paste text</strong><span>Type or paste anything</span></button>
          <button class="hero-import-option" type="button" data-open-tab="upload"><strong>Upload a file</strong><span>PDF, EPUB, or TXT</span></button>
          <button class="hero-import-option" type="button" data-open-tab="ocr"><strong>Scan an image</strong><span>On-device OCR</span></button>
          <button class="hero-import-option" type="button" data-open-tab="url"><strong>Extract a web link</strong><span>Pull in an article</span></button>
        </div>
      </section>

      <!-- ---------------- READER SCREEN ---------------- -->
      <div id="reader-screen" class="glass app-card hidden mb-6">
        <div class="reader-header">
          <h3>Reader</h3>
          <button class="btn btn-secondary btn-sm" id="btn-close-reader">✕ Close</button>
        </div>

        <!-- Reading Mode Switcher -->
        <div class="mode-switcher mt-4">
          <button class="mode-btn active" data-mode="rsvp">RSVP</button>
          <button class="mode-btn" data-mode="bionic">Bionic</button>
          <button class="mode-btn" data-mode="standard">Standard</button>
        </div>

        <!-- Interactive Workspace -->
        <div class="reader-display-container">
          
          <!-- RSVP (Visual Flash) Pane -->
          <div id="rsvp-pane" class="reader-pane active">
            <div class="rsvp-word-container">
              <div class="rsvp-focus-line"></div>
              <div class="rsvp-horizontal-ticks">
                <div class="rsvp-tick"></div>
                <div class="rsvp-tick"></div>
              </div>
              <div class="word-wrapper">
                <span class="word-left" id="word-left">Ready</span>
                <span class="word-orp" id="word-orp">.</span>
                <span class="word-right" id="word-right"></span>
              </div>
            </div>
            <div class="rsvp-progress-bar-container">
              <div class="rsvp-progress-bar" id="rsvp-progress"></div>
            </div>
          </div>

          <!-- Bionic Reader Pane -->
          <div id="bionic-pane" class="reader-pane hidden">
            <div class="standard-reader-view" id="bionic-text-view">
              <!-- Highlighted bionic text gets loaded here -->
            </div>
          </div>

          <!-- Standard Mode Pane -->
          <div id="standard-pane" class="reader-pane hidden">
            <div class="standard-reader-view" id="standard-text-view">
              <!-- Sentences loaded here with click-to-jump -->
            </div>
          </div>

        </div>

        <!-- Controls HUD -->
        <div class="controls-hud mt-4">
          
          <!-- Playback controls -->
          <div class="playback-controls">
            <button class="control-btn" id="btn-rsvp-prev" title="Previous word (ArrowLeft)">⏮</button>
            <button class="control-btn play-btn" id="btn-rsvp-play" title="Play/Pause (Space)">▶ Play</button>
            <button class="control-btn" id="btn-rsvp-next" title="Next word (ArrowRight)">⏭</button>
            <button class="control-btn" id="btn-rsvp-tts" title="Toggle Text-to-Speech Audio">Audio Sync: Off</button>
            <button class="control-btn" id="btn-fullscreen" title="Toggle distraction-free fullscreen">Fullscreen</button>
          </div>

          <!-- Setting Tuners -->
          <div class="tuner-grid">
            <div class="tuner-card">
              <label for="slider-wpm">Reading Speed: <span id="wpm-display">300</span> WPM</label>
              <input type="range" id="slider-wpm" min="100" max="1000" step="25" value="300" />
            </div>
            
            <div class="tuner-card">
              <label>Theme Preset</label>
              <div class="theme-picker">
                <button class="theme-badge light" data-theme="light" title="Light theme">A</button>
                <button class="theme-badge sepia" data-theme="sepia" title="Sepia eye-comfort">A</button>
                <button class="theme-badge dark" data-theme="dark" title="Dark theme">A</button>
                <button class="theme-badge amoled" data-theme="amoled" title="AMOLED Black">A</button>
              </div>
            </div>

            <div class="tuner-card">
              <label for="select-font">Font Family</label>
              <select id="select-font">
                <option value="sans">Sans-Serif (Inter)</option>
                <option value="serif">Serif (Merriweather)</option>
                <option value="dyslexic">Dyslexic Aid (OpenDyslexic)</option>
              </select>
            </div>

            <div class="tuner-card">
              <label for="slider-font-size">Font Size: <span id="font-size-display">24</span>px</label>
              <input type="range" id="slider-font-size" min="16" max="48" step="2" value="24" />
            </div>

            <div class="tuner-card">
              <label for="select-voice">Audio Sync Voice</label>
              <select id="select-voice">
                <option value="">Default System Voice</option>
              </select>
              <span class="tuner-hint">Use Chrome/Edge for Natural Neural voices</span>
            </div>

            <div class="tuner-card">
              <label for="slider-pitch">Voice Pitch: <span id="pitch-display">1.0</span></label>
              <input type="range" id="slider-pitch" min="0.5" max="2.0" step="0.1" value="1.0" />
            </div>
          </div>

          <!-- Position/Timeline slider -->
          <div class="timeline-row">
            <input type="range" id="slider-progress" min="0" max="100" value="0" />
            <div class="timeline-labels">
              <span id="reading-time-left">0 min remaining</span>
              <span id="reading-percentage">Word 0 / 0 (0%)</span>
            </div>
          </div>

        </div>

      </div>

      <!-- ---------------- IMPORTER CARD ---------------- -->
      <div class="glass app-card" id="importer-card">
        <div class="importer-heading">
          <div>
            <h2>Bring in text</h2>
            <p class="muted">Choose one source. AI works on the document you load here.</p>
          </div>
          <p class="document-status" id="document-status" role="status">No document loaded yet</p>
        </div>
        
        <div class="tabs" aria-label="Document sources">
          <button class="tab-btn active" data-tab="paste">Paste text</button>
          <button class="tab-btn" data-tab="upload">Upload file</button>
          <button class="tab-btn" data-tab="ocr">Image OCR</button>
          <button class="tab-btn" data-tab="url">Extract URL</button>
        </div>

        <!-- Import Panels -->
        <div class="tab-contents">
          
          <!-- Paste Panel -->
          <div class="tab-content active" id="tab-paste">
            <textarea id="text-input" placeholder="Paste your article, book chapter, or text here to start speed reading..."></textarea>
            
            <!-- Find & Replace Accordion -->
            <details class="text-clean-details mt-2">
              <summary>Text cleaning tools (Find &amp; Replace)</summary>
              <div class="find-replace-grid mt-2">
                <input type="text" id="input-find" placeholder="Find text..." />
                <input type="text" id="input-replace" placeholder="Replace with..." />
                <button class="btn btn-secondary btn-sm" id="btn-run-replace">Replace All</button>
              </div>
            </details>

            <div class="input-actions mt-4">
              <button class="btn btn-primary" id="btn-load-paste">Start reading</button>
              <button class="btn btn-secondary" id="btn-demo">Try demo text</button>
            </div>
          </div>

          <!-- Upload Panel -->
          <div class="tab-content" id="tab-upload">
            <div class="dropzone" id="file-dropzone">
              <p>Drag and drop a file here, or <span class="browse-link">browse files</span></p>
              <span class="dropzone-formats">Supports PDF, EPUB, TXT</span>
              <input type="file" id="file-input" accept=".pdf,.epub,.txt" class="hidden" />
            </div>
            <div id="file-progress" class="hidden">
              <div class="progress-bar-container"><div class="progress-bar" id="upload-progress-bar"></div></div>
              <p id="file-status" role="status" aria-live="polite">Parsing file...</p>
            </div>
          </div>

          <!-- OCR Panel -->
          <div class="tab-content" id="tab-ocr">
            <div class="dropzone" id="ocr-dropzone">
              <p>Drag and drop an image / screenshot of text, or <span class="browse-link">browse files</span></p>
              <span class="dropzone-formats">Extracts text client-side using On-Device OCR</span>
              <input type="file" id="ocr-input" accept="image/*" class="hidden" />
            </div>
            <div id="ocr-progress" class="hidden">
              <div class="progress-bar-container"><div class="progress-bar" id="ocr-progress-bar"></div></div>
              <p id="ocr-status">Initializing Tesseract OCR...</p>
            </div>
          </div>

          <!-- URL Panel -->
          <div class="tab-content" id="tab-url">
            <div class="url-input-container">
              <input type="url" id="url-input" placeholder="Enter article or webpage URL (e.g., https://example.com/article)" />
              <button class="btn btn-primary" id="btn-load-url">Extract Text</button>
            </div>
            <p class="input-hint">Fetches core text from a public webpage through SpeedRead's extractor, then opens it in your reader.</p>
          </div>

          <section class="ai-workspace" aria-labelledby="ai-workspace-title">
            <div class="ai-workspace-copy">
              <h3 id="ai-workspace-title">AI workspace</h3>
              <p id="ai-document-status">Load a document above, then summarize it or ask questions about it.</p>
            </div>
            <div class="ai-config">
              <label for="ai-key">Gemini API Key (stored locally):</label>
              <div class="key-input-row">
                <input type="password" id="ai-key" placeholder="Enter your Gemini API Key..." />
                <button class="btn btn-secondary" id="btn-save-key">Save Key</button>
                <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener" class="api-link">Get a Gemini key ↗</a>
              </div>
              <details class="gemini-guide">
                <summary>How to get a Gemini API key</summary>
                <ol>
                  <li>Open Google AI Studio and sign in.</li>
                  <li>Select <strong>Create API key</strong> and choose or create a Google Cloud project.</li>
                  <li>Copy the key, paste it above, and select <strong>Save Key</strong>.</li>
                  <li>Keep it private. SpeedRead stores it only in this browser.</li>
                </ol>
                <p>Google offers a free Gemini API tier with usage limits. Some models, regions and higher-volume use may require billing.</p>
              </details>
            </div>
            <div class="ai-actions">
              <button class="btn btn-primary" id="btn-ai-summary" disabled>Generate summary</button>
              <button class="btn btn-secondary" id="btn-ai-chat" disabled>Chat with document</button>
            </div>
            
            <div id="ai-response-box" class="hidden glass mt-4">
              <div class="ai-box-header">
                <h4 id="ai-response-title">AI Summary</h4>
                <button class="btn btn-secondary btn-sm" id="btn-close-ai-box">✕ Close</button>
              </div>
              <div id="ai-summary-view">
                <p id="ai-response-text" class="summary-text"></p>
              </div>
              <div id="ai-chat-view" class="hidden">
                <div class="chat-history" id="chat-history"></div>
                <div class="chat-input-row">
                  <input type="text" id="chat-user-input" placeholder="Ask a question about your document..." />
                  <button class="btn btn-primary" id="btn-send-chat">Send</button>
                </div>
              </div>
            </div>
          </section>

        </div>
      </div>
    </div>
  </section>

  <section class="launch-paths" aria-labelledby="launch-paths-title">
    <div class="container">
      <div class="launch-paths-heading">
        <h2 id="launch-paths-title">One reader. Four ways in.</h2>
        <p>Use the smallest capture flow that fits what you are reading.</p>
      </div>
      <div class="launch-paths-list">
        <a href="#importer-card" class="launch-path">
          <span class="launch-path-mark" aria-hidden="true"></span>
          <span><strong>Paste or upload</strong><small>Text, PDF, EPUB, TXT or image OCR</small></span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/extension" class="launch-path">
          <span class="launch-path-mark" aria-hidden="true"></span>
          <span><strong>Chrome extension</strong><small>Send the active article in one click</small></span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/bookmarklet" class="launch-path">
          <span class="launch-path-mark" aria-hidden="true"></span>
          <span><strong>Bookmarklet</strong><small>No install, just drag it to your bookmarks bar</small></span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="#importer-card" class="launch-path" data-open-tab="url">
          <span class="launch-path-mark" aria-hidden="true"></span>
          <span><strong>Public URL</strong><small>Pull the article body into the reader</small></span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Google AdSense — hidden when Premium active -->
  <section class="ads-section ads-section-top">
    <div class="container">
      <AdSlot placement="TOP" format="horizontal" />
    </div>
  </section>

  <!-- Monetization & Analytics Section -->
  <section class="pricing-analytics-section mt-8" id="pricing">
    <div class="container pricing-analytics-grid">
      
      <!-- Analytics Stored locally -->
      <div class="glass dashboard-card">
        <h3>Your reading dashboard</h3>
        <p class="muted">Your statistics are stored entirely in your local browser.</p>
        <div class="stats-grid mt-4">
          <div class="stat-box">
            <span class="stat-value" id="stats-words">0</span>
            <span class="stat-label">Words Speed-Read</span>
          </div>
          <div class="stat-box">
            <span class="stat-value" id="stats-time">0m</span>
            <span class="stat-label">Time Spent Reading</span>
          </div>
          <div class="stat-box">
            <span class="stat-value" id="stats-saved">0m</span>
            <span class="stat-label">Estimated Time Saved</span>
          </div>
          <div class="stat-box">
            <span class="stat-value" id="stats-streak">0</span>
            <span class="stat-label">Day Streak</span>
          </div>
        </div>
        <div class="actions mt-6">
          <button class="btn btn-secondary" id="btn-share-stats">Share achievement</button>
        </div>
      </div>

      <!-- Lifetime Premium Block -->
      <div class="glass pricing-card premium-badge">
        <div class="pricing-tag">Lifetime</div>
        <h3>Lifetime Premium</h3>
        <div class="price-row mt-2">
          <span class="price-strike">$29.99</span>
          <span class="price-value">$9.00</span>
          <span class="price-term">one-time / forever</span>
        </div>
        <ul class="pricing-features mt-4">
          <li>100% ad-free reading environment</li>
          <li>Unlimited document length (no 3,000-word cap)</li>
          <li>Gemini AI summary &amp; chat (no API key needed)</li>
          <li>Multi-device license (up to 5 devices, revocable)</li>
          <li>Neural TTS voices (Chrome/Edge system voices)</li>
        </ul>
        <div class="pricing-actions mt-6">
          <button class="btn btn-primary w-full" id="btn-buy-premium">Get Lifetime Pro — $9</button>
          <p class="muted text-center mt-2">One-time payment. Activate up to 5 personal devices.</p>
        </div>

        <!-- Multi-device license: activate key + device slots (max 5) -->
        <div class="license-panel mt-6" id="license-panel">
          <h4 class="license-heading">Already purchased?</h4>
          <p class="muted license-hint">Paste your lifetime license key. Premium binds to this device (max 5 devices). Sharing past the limit is blocked.</p>
          <div class="license-row">
            <input type="text" id="license-key-input" placeholder="Paste license key…" autocomplete="off" spellcheck="false" aria-label="License key" />
            <button class="btn btn-secondary" id="btn-activate-license" type="button">Activate device</button>
          </div>
          <p id="license-status" class="license-status muted" role="status" aria-live="polite"></p>
          <div id="license-display" class="license-display hidden">
            <label for="license-key-display">License key (keep private — save offline)</label>
            <div class="license-row">
              <input type="text" id="license-key-display" readonly aria-label="Saved license key" />
              <button class="btn btn-secondary btn-sm" id="btn-copy-license" type="button">Copy</button>
            </div>
          </div>
          <div id="device-list-wrap" class="device-list-wrap hidden">
            <div class="device-list-header">
              <span>Activated devices</span>
              <span id="device-count" class="device-count"></span>
            </div>
            <ul id="device-list" class="device-list"></ul>
            <p class="muted device-help">Revoke a device you no longer use to free a slot. Max 5 personal devices.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ---------------- SEO CONTENT LAYER ---------------- -->
  <section class="seo-content-section mt-12">
    <div class="container">
      <div class="seo-layout">
        
        <div class="seo-text">
          <h2 class="seo-title">Free Online Speed Reader — Flash RSVP &amp; Bionic Reading Web App</h2>
          <p>
            SpeedRead is a free online speed reader for eBooks, web articles, PDFs, and textbooks at up to 1000+ words per minute (WPM). It combines RSVP (Rapid Serial Visual Presentation), bionic reading, and synchronized text-to-speech so you can reduce eye fatigue, cut sub-vocalization, and finish long material faster — without installing an app or creating an account.
          </p>

          <h2>How to use this online speed reader</h2>
          <ol class="seo-steps">
            <li><strong>Load text</strong> — paste an article, upload PDF/EPUB/TXT, run image OCR, or extract a public URL (or use the bookmarklet / Chrome extension).</li>
            <li><strong>Start reading</strong> — RSVP mode flashes one word at a time with Optimal Recognition Point (ORP) alignment.</li>
            <li><strong>Tune speed</strong> — set WPM from 100–1000, press Space to play/pause, and use arrow keys to jump.</li>
            <li><strong>Optional audio</strong> — enable Audio Sync for dual-channel TTS, or switch to Bionic / Standard page view.</li>
            <li><strong>Themes</strong> — light, sepia, dark, or AMOLED; press <kbd>D</kbd> to cycle.</li>
          </ol>
          
          <h2>Rapid Serial Visual Presentation (RSVP)</h2>
          <p>
            Traditional reading forces horizontal eye movement and micro-pauses (saccades). RSVP mode flashes single words at a fixed focal point. SpeedRead calculates the Optimal Recognition Point of each word — the focal letter is highlighted — so your brain processes language without hunting along a line. Punctuation gets slightly longer delays so comprehension stays intact at high WPM.
          </p>
          
          <h2>Bionic Reading Mode</h2>
          <p>
            For longer sessions where you want a full page, bionic reading bolds the initial part of each word (fixations) while the rest stays lighter (saccades). Your eyes glide through paragraphs with lower load. Switch anytime between <a href="/bionic-reading">bionic reading</a>, <a href="/rsvp-reader">RSVP</a>, and standard sentence mode without reloading the document.
          </p>
          
          <h2>Dual-Channel Audio Narration &amp; PDF to speech</h2>
          <p>
            Layering TTS on visual flashes creates dual-channel focus: ears and eyes stay on the same stream. Use Chrome or Edge for neural/natural voices. Upload a PDF or EPUB and narrate client-side — see also our <a href="/pdf-to-speech">PDF to speech</a> guide. Files are parsed in the browser; optional URL extraction and AI features call first-party or Google APIs as described in the privacy policy.
          </p>

          <h2>Common use cases</h2>
          <ul class="seo-usecases">
            <li><strong>Students</strong> — revise chapters and papers faster before exams or case comps.</li>
            <li><strong>Professionals</strong> — clear newsletters, research PDFs, and long emails under time pressure.</li>
            <li><strong>Language practice</strong> — pair visual RSVP with audio to reinforce pacing.</li>
            <li><strong>Accessibility preference</strong> — choose bionic bolding, dyslexia-friendly font option, or high-contrast AMOLED.</li>
            <li><strong>Web clipping</strong> — send any public article into the reader with one bookmarklet click.</li>
          </ul>
        </div>

        <!-- FAQs Section for Structured Schema -->
        <div class="faq-container mt-12">
          <h2>Frequently Asked Questions</h2>
          
          <details class="faq-item" open>
            <summary>What is RSVP Speed Reading?</summary>
            <div class="faq-answer">
              <p>RSVP stands for Rapid Serial Visual Presentation. It is a visual reading technology that flashes single words sequentially on a static point on the screen. This allows you to read without moving your eyes horizontally, eliminating eye muscle fatigue and significantly increasing reading speeds.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>How does Bionic Reading work?</summary>
            <div class="faq-answer">
