    .hero-import-rail { margin-top: clamp(2rem, 5vw, 4rem); padding: clamp(1.25rem, 3vw, 2rem); border: 1px solid var(--color-border); border-radius: var(--radius-xl); background: var(--color-bg-card); animation: rail-enter 700ms 180ms var(--ease-out) both; }
