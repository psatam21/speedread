  <!-- Core JavaScript Script Loader & App Logic -->
  <script is:inline>
    // State management
    const state = {
      text: "",
      words: [],
      wordObjects: [],
      currentIndex: 0,
      wpm: 300,
      isPlaying: false,
      mode: 'rsvp', // rsvp, bionic, standard
      theme: 'light',
      font: 'sans',
      fontSize: 24,
      sourceLabel: '',
      ttsActive: false,
      timer: null,
      ttsUtterance: null,
      isPremium: false,
      stats: {
        wordsRead: 0,
        timeSpent: 0,
        streak: 0,
        lastReadDate: ""
      }
    };

    // ── Device-bound premium ──────────────────────────────────────────
    const getDeviceId = () => {
      let id = localStorage.getItem('device_id');
      if (!id) {
        id = (typeof crypto !== 'undefined' && crypto.randomUUID)
          ? crypto.randomUUID()
          : `d-${Date.now()}-${Math.random().toString(36).slice(2, 12)}`;
        localStorage.setItem('device_id', id);
      }
      return id;
    };

    const getDeviceLabel = () => {
      const ua = navigator.userAgent || '';
      let browser = 'Browser';
      if (/Edg\//.test(ua)) browser = 'Edge';
      else if (/Chrome\//.test(ua)) browser = 'Chrome';
      else if (/Firefox\//.test(ua)) browser = 'Firefox';
      else if (/Safari\//.test(ua)) browser = 'Safari';
      let os = 'Device';
      if (/Windows/.test(ua)) os = 'Windows';
      else if (/Mac OS|Macintosh/.test(ua)) os = 'Mac';
      else if (/Android/.test(ua)) os = 'Android';
      else if (/iPhone|iPad/.test(ua)) os = 'iOS';
      return `${browser} on ${os}`;
    };

    const getStoredLicenseKey = () => localStorage.getItem('license_key') || '';
    /** Device session only — never fall back to raw license key for APIs */
    const getDeviceSession = () => localStorage.getItem('premium_token') || '';

    const clearPremiumLocal = () => {
      localStorage.removeItem('is_premium');
      localStorage.removeItem('premium_token');
      state.isPremium = false;
    };

    const renderDeviceList = (devices = [], maxDevices = 5) => {
      const wrap = document.getElementById('device-list-wrap');
      const list = document.getElementById('device-list');
      const count = document.getElementById('device-count');
      if (!wrap || !list) return;
      if (!devices.length) {
        wrap.classList.add('hidden');
        return;
      }
      wrap.classList.remove('hidden');
      if (count) count.textContent = `${devices.length} / ${maxDevices}`;
      const currentId = getDeviceId();
      list.innerHTML = devices.map((d) => {
        const label = (d.label || 'Device').replace(/</g, '&lt;');
        const current = d.id === currentId || d.is_current;
        const idAttr = String(d.id).replace(/"/g, '');
        return `<li class="device-item${current ? ' is-current' : ''}">
          <span class="device-item-label">${label}${current ? ' <em>(this device)</em>' : ''}</span>
          ${current ? '' : `<button type="button" class="btn btn-secondary btn-sm btn-revoke-device" data-device-id="${idAttr}">Revoke</button>`}
        </li>`;
      }).join('');
    };

    const unlockPremium = ({ licenseKey, sessionToken, devices, maxDevices }) => {
      if (licenseKey) localStorage.setItem('license_key', licenseKey);
      if (sessionToken) {
        localStorage.setItem('premium_token', sessionToken);
        localStorage.setItem('is_premium', 'true');
        state.isPremium = true;
      }
      if (devices) {
        try { localStorage.setItem('premium_devices', JSON.stringify({ devices, maxDevices: maxDevices || 5 })); } catch (_) {}
        renderDeviceList(devices, maxDevices || 5);
      }
      applyPremiumUI();
    };

    const applyPremiumUI = () => {
      const licenseDisplay = document.getElementById('license-display');
      const licenseKeyDisplay = document.getElementById('license-key-display');
      const storedKey = getStoredLicenseKey();

      if (storedKey && licenseKeyDisplay) {
        licenseKeyDisplay.value = storedKey;
        if (licenseDisplay) licenseDisplay.classList.remove('hidden');
      }

      try {
        const cached = JSON.parse(localStorage.getItem('premium_devices') || 'null');
        if (cached?.devices) renderDeviceList(cached.devices, cached.maxDevices || 5);
      } catch (_) {}

      if (state.isPremium && getDeviceSession()) {
        document.querySelectorAll('.ads-section').forEach(el => el.classList.add('hidden'));
        
        const buyBtn = document.getElementById('btn-buy-premium');
        if (buyBtn) {
          buyBtn.textContent = "Premium active on this device";
          buyBtn.disabled = true;
          buyBtn.classList.add('btn-premium-active');
        }
        
        const pricingCard = document.querySelector('.pricing-card');
        if (pricingCard) {
          const tag = pricingCard.querySelector('.pricing-tag');
          if (tag) {
            tag.textContent = "Active on this device";
            tag.classList.add('tag-success');
          }
        }

        const heading = document.querySelector('.license-heading');
        if (heading) heading.textContent = "Your license & devices";
        const hint = document.querySelector('.license-hint');
        if (hint) hint.textContent = "Keep the key private. Activate on up to 5 devices. Revoke unused devices to free slots.";
      }
    };

    /**
     * Validate premium without burning an extra device slot.
     * - Extension handoff already provides a device session → trust it (no re-bind).
     * - Web-native session present → keep offline-capable; re-bind only if missing session.
     * - Forged is_premium without license → strip.
     */
    const revalidatePremium = async () => {
      const license = getStoredLicenseKey();
      const session = getDeviceSession();
      const forgedFlag = localStorage.getItem('is_premium') === 'true' && !license && !session;
      if (forgedFlag) {
        clearPremiumLocal();
        applyPremiumUI();
        return;
      }

      // Session from extension or prior activate: do not re-POST activate (would double-bind)
      if (session) {
        state.isPremium = true;
        localStorage.setItem('is_premium', 'true');
        applyPremiumUI();
        return;
      }

      if (!license) return;

      try {
        const res = await fetch('/api/activate-license', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            license_key: license,
            device_id: getDeviceId(),
            device_label: getDeviceLabel(),
          }),
        });
        const data = await res.json();
        if (res.ok && data.ok && data.token) {
          unlockPremium({
            licenseKey: data.license_key || license,
            sessionToken: data.token,
            devices: data.devices,
            maxDevices: data.max_devices,
          });
        } else if (data.code === 'DEVICE_LIMIT') {
          localStorage.removeItem('premium_token');
          localStorage.setItem('is_premium', 'false');
          state.isPremium = false;
          if (data.devices) renderDeviceList(data.devices, data.max_devices || 5);
          applyPremiumUI();
          const status = document.getElementById('license-status');
          if (status) status.textContent = data.error || 'Device limit reached. Revoke another device.';
        } else if (data.code === 'INVALID_KEY' || res.status === 401) {
          localStorage.removeItem('license_key');
          clearPremiumLocal();
          applyPremiumUI();
        }
      } catch (_) {
        state.isPremium = localStorage.getItem('is_premium') === 'true' && !!getDeviceSession();
        applyPremiumUI();
      }
    };

    const loadState = () => {
      state.wpm = parseInt(localStorage.getItem('wpm') || '300');
      state.theme = localStorage.getItem('theme') || 'light';
      state.font = localStorage.getItem('font') || 'sans';
      state.fontSize = parseInt(localStorage.getItem('fontSize') || '24');
      // Require device session — bare license key or forged flag is not enough
      state.isPremium = localStorage.getItem('is_premium') === 'true' && !!getDeviceSession();
      
      const statsJson = localStorage.getItem('stats');
      if (statsJson) {
        state.stats = JSON.parse(statsJson);
      } else {
        state.stats = { wordsRead: 0, timeSpent: 0, streak: 0, lastReadDate: "" };
      }
      
      document.getElementById('slider-wpm').value = state.wpm;
      document.getElementById('wpm-display').textContent = state.wpm;
      
      document.getElementById('slider-font-size').value = state.fontSize;
      document.getElementById('font-size-display').textContent = state.fontSize;
      
      document.getElementById('select-font').value = state.font;
      document.documentElement.setAttribute('data-font', state.font);
      
      updateStatsUI();
      applyPremiumUI();
      revalidatePremium();
    };

    const updateStatsUI = () => {
      document.getElementById('stats-words').textContent = state.stats.wordsRead.toLocaleString();
      document.getElementById('stats-time').textContent = Math.round(state.stats.timeSpent) + 'm';
      
      // Traditional reading speed is 200 WPM
      // SpeedRead saves time = (Words Read / 200) - (Words Read / RSVP WPM)
      const traditionalTime = state.stats.wordsRead / 200;
      const speedreadTime = state.stats.timeSpent; // actual reading time
      const timeSaved = Math.max(0, traditionalTime - speedreadTime);
      document.getElementById('stats-saved').textContent = Math.round(timeSaved) + 'm';
      
      // Validate streak
      const today = new Date().toDateString();
      if (state.stats.lastReadDate === today) {
        // Already read today, streak is valid
      } else {
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        if (state.stats.lastReadDate === yesterday.toDateString()) {
          // Read yesterday, streak is valid
        } else if (state.stats.lastReadDate !== "") {
          // Broke streak
          state.stats.streak = 0;
        }
      }
      document.getElementById('stats-streak').textContent = state.stats.streak;
    };

    const saveStats = () => {
      localStorage.setItem('stats', JSON.stringify(state.stats));
      updateStatsUI();
    };

    // Calculate ORP character index
    const getOrpIndex = (word) => {
      const len = word.length;
      if (len <= 1) return 0;
      if (len <= 5) return 1;
      if (len <= 9) return 2;
      if (len <= 13) return 3;
      return 4;
    };

    // Parse text to word mappings with coordinate tracking
    const parseText = (textVal) => {
      state.text = textVal;
      state.words = textVal.trim().split(/\s+/).filter(w => w.length > 0);
      
      state.wordObjects = [];
      const wordRegex = /\S+/g;
      let match;
      while ((match = wordRegex.exec(textVal)) !== null) {
        state.wordObjects.push({
          word: match[0],
          startIndex: match.index,
          endIndex: match.index + match[0].length
        });
      }
      state.currentIndex = 0;
    };

    const updateDocumentContext = () => {
      const hasDocument = Boolean(state.text.trim());
      const source = state.sourceLabel || 'Document';
      const wordCount = state.words.length.toLocaleString();
      const status = hasDocument ? `Loaded: ${source} · ${wordCount} words` : 'No document loaded yet';
      document.getElementById('document-status').textContent = status;
      document.getElementById('ai-document-status').textContent = hasDocument
        ? `Ready to work with ${source} (${wordCount} words).`
        : 'Load a document above, then summarize it or ask questions about it.';
      document.getElementById('btn-ai-summary').disabled = !hasDocument;
      document.getElementById('btn-ai-chat').disabled = !hasDocument;
    };

    let ttsVisualQueue = [];
    let ttsVisualTimer = null;

    const renderQueuedTTSWord = () => {
      ttsVisualTimer = null;
      const nextIndex = ttsVisualQueue.shift();
      if (nextIndex === undefined || !state.isPlaying) return;

      state.currentIndex = nextIndex;
      state.stats.wordsRead += 1;
      state.stats.timeSpent += 1 / state.wpm;
      if (state.stats.wordsRead % 50 === 0) saveStats();
      renderRSVPWord();

      if (ttsVisualQueue.length) {
        ttsVisualTimer = setTimeout(renderQueuedTTSWord, Math.max(16, 60000 / state.wpm));
      }
    };

    const queueTTSVisualWord = (matchedIndex) => {
      const lastIndex = ttsVisualQueue.length ? ttsVisualQueue[ttsVisualQueue.length - 1] : state.currentIndex;
      for (let index = lastIndex + 1; index <= matchedIndex; index += 1) {
        ttsVisualQueue.push(index);
      }
      if (!ttsVisualTimer && ttsVisualQueue.length) renderQueuedTTSWord();
    };

    // Display current RSVP word
    const renderRSVPWord = () => {
      if (state.currentIndex >= state.words.length) {
        pauseReader();
        state.currentIndex = state.words.length - 1;
        return;
      }
      const word = state.words[state.currentIndex];
      if (!word) return;

      const orpIdx = getOrpIndex(word);
      const left = word.substring(0, orpIdx);
      const orp = word.charAt(orpIdx);
      const right = word.substring(orpIdx + 1);

      // Render segments
      document.getElementById('word-left').textContent = left;
      document.getElementById('word-orp').textContent = orp;
      document.getElementById('word-right').textContent = right;

      // Update progress sliders
      const percentage = Math.round((state.currentIndex / Math.max(1, state.words.length - 1)) * 100);
      document.getElementById('rsvp-progress').style.width = percentage + '%';
      document.getElementById('slider-progress').value = percentage;
      document.getElementById('reading-percentage').textContent = `Word ${state.currentIndex + 1} / ${state.words.length} (${percentage}%)`;
      
      // Est. remaining time
      const wordsLeft = state.words.length - state.currentIndex;
      const minLeft = Math.ceil(wordsLeft / state.wpm);
      document.getElementById('reading-time-left').textContent = `${minLeft} min remaining`;
    };

    // Main RSVP playback loop
    const playRSVP = () => {
      if (state.currentIndex >= state.words.length) {
        state.currentIndex = 0;
      }
      state.isPlaying = true;
      ttsVisualQueue = [];
      clearTimeout(ttsVisualTimer);
      ttsVisualTimer = null;
      document.getElementById('btn-rsvp-play').textContent = "⏸ Pause";
      if (state.ttsActive) {
        speakWithTTS();
      } else {
        runRSVPTimer();
      }

      // Record streak activity
      const today = new Date().toDateString();
      if (state.stats.lastReadDate !== today) {
        if (state.stats.lastReadDate === new Date(Date.now() - 86400000).toDateString()) {
          state.stats.streak += 1;
        } else if (state.stats.streak === 0) {
          state.stats.streak = 1;
        }
        state.stats.lastReadDate = today;
        saveStats();
      }
    };

    const runRSVPTimer = () => {
      if (!state.isPlaying) return;

      if (state.currentIndex >= state.words.length) {
        pauseReader();
        state.currentIndex = state.words.length - 1;
        saveStats();
        return;
      }

      const word = state.words[state.currentIndex];
      const baseDelay = (60 / state.wpm) * 1000;
      
      // Intelligent pause delay mapping for punctuation
      let delay = baseDelay;
      if (word) {
        if (/[.!?]$/.test(word)) delay = baseDelay * 1.8;
        else if (/[,;:]$/.test(word)) delay = baseDelay * 1.3;
      }

      // Record reading stats in memory
      state.stats.wordsRead += 1;
      state.stats.timeSpent += (delay / 60000); // convert delay to fractional minutes
      
      // Save stats to disk only every 50 words to prevent I/O blocking
      if (state.stats.wordsRead % 50 === 0) {
        saveStats();
      }

      renderRSVPWord();
      state.currentIndex++;

      // Never compress delayed frames into zero-delay callbacks: every word needs a paint.
      state.timer = setTimeout(runRSVPTimer, delay);
    };

    const pauseReader = () => {
      state.isPlaying = false;
      document.getElementById('btn-rsvp-play').textContent = "▶ Play";
      clearTimeout(state.timer);
      clearTimeout(ttsVisualTimer);
      ttsVisualTimer = null;
      ttsVisualQueue = [];
      if (window.speechSynthesis) {
        window.speechSynthesis.cancel();
      }
      // Save stats immediately on pause
      saveStats();
    };

    // Text-to-Speech Synchronization using Web Speech API
    const speakWithTTS = () => {
      if (!window.speechSynthesis) {
        alert("Text to speech is not supported in this browser.");
        return;
      }
      window.speechSynthesis.cancel();

      const startIndexOffset = state.wordObjects[state.currentIndex]?.startIndex || 0;
      // CRITICAL: Slice directly from original text to keep word character offsets perfectly aligned
      const remainingText = state.text.slice(startIndexOffset);

      state.ttsUtterance = new SpeechSynthesisUtterance(remainingText);
      state.ttsUtterance.rate = Math.min(3.0, Math.max(0.5, state.wpm / 150)); // Map WPM to speech rate (standard is ~150 WPM)
      state.ttsUtterance.pitch = parseFloat(document.getElementById('slider-pitch').value || '1.0');

      // Set chosen voice from selection dropdown
      const selectedVoiceName = document.getElementById('select-voice').value;
      const voices = window.speechSynthesis.getVoices();
      if (selectedVoiceName && voices.length > 0) {
        state.ttsUtterance.voice = voices.find(v => v.name === selectedVoiceName);
      } else if (voices.length > 0) {
        // Prioritize English neural/natural/online voices for a realistic human feel
        const neuralVoice = voices.find(v => v.lang.startsWith('en') && 
          (v.name.includes('Natural') || v.name.includes('Neural') || v.name.includes('Google') || v.name.includes('Online') || v.localService === false)
        );
        state.ttsUtterance.voice = neuralVoice || voices.find(v => v.lang.startsWith('en')) || voices[0];
      }

      state.ttsUtterance.onboundary = (event) => {
        if (event.name === 'word' && state.isPlaying) {
          const charIndex = event.charIndex + startIndexOffset;
          
          // Find matching word based on character coordinates
          let matchedIdx = -1;
          for (let i = 0; i < state.wordObjects.length; i++) {
            const w = state.wordObjects[i];
            if (charIndex >= w.startIndex && charIndex < w.endIndex) {
              matchedIdx = i;
              break;
            }
          }
          
          // Fallback: if charIndex falls on space/punctuation, align to the word immediately preceding it
          if (matchedIdx === -1) {
            matchedIdx = state.wordObjects.findIndex(w => w.startIndex > charIndex) - 1;
          }

          if (matchedIdx !== -1) queueTTSVisualWord(matchedIdx);
        }
      };

      state.ttsUtterance.onend = () => {
        pauseReader();
        state.currentIndex = state.words.length;
        saveStats();
      };

      state.ttsUtterance.onerror = (e) => {
        console.error("TTS speech error", e);
        pauseReader();
      };

      window.speechSynthesis.speak(state.ttsUtterance);
    };

    // Escape HTML special chars so pasted/extracted text can't be rendered as markup
    const escapeHtml = (str) => str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Render Bionic Reading format
    const renderBionicText = () => {
      const formatted = state.words.map(word => {
        if (word.length <= 1) return escapeHtml(word);
        let fixLen = Math.ceil(word.length * 0.4);
        if (word.length === 3) fixLen = 2;
        const fixPart = escapeHtml(word.slice(0, fixLen));
        const sacPart = escapeHtml(word.slice(fixLen));
        return `<strong class="bionic-fixation">${fixPart}</strong><span class="bionic-saccade">${sacPart}</span>`;
      }).join(' ');

      document.getElementById('bionic-text-view').innerHTML = formatted;
    };

    // Render Standard Reader highlighted sentences
    const renderStandardText = () => {
      // Split text by sentences
      const sentences = state.text.match(/[^.!?]+[.!?]+(\s|$)/g) || [state.text];
      const html = sentences.map((sentence, idx) => {
        return `<span class="reader-sentence" data-sentence-index="${idx}">${escapeHtml(sentence)}</span>`;
      }).join('');
      
      const view = document.getElementById('standard-text-view');
      view.innerHTML = html;

      // Click to jump logic
      view.querySelectorAll('.reader-sentence').forEach(el => {
        el.addEventListener('click', (e) => {
          view.querySelectorAll('.reader-sentence').forEach(s => s.classList.remove('active'));
          el.classList.add('active');
          
          // Map sentence jump back to RSVP word index
          const sText = el.textContent.trim().split(/\s+/)[0];
          const matchedWordIdx = state.words.findIndex(w => w.startsWith(sText));
          if (matchedWordIdx !== -1) {
            state.currentIndex = matchedWordIdx;
            renderRSVPWord();
          }
        });
      });
    };

    // Setup active mode panes
    const setMode = (modeName) => {
      state.mode = modeName;
      document.querySelectorAll('.mode-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.mode === modeName);
      });

      document.getElementById('rsvp-pane').classList.toggle('hidden', modeName !== 'rsvp');
      document.getElementById('bionic-pane').classList.toggle('hidden', modeName !== 'bionic');
      document.getElementById('standard-pane').classList.toggle('hidden', modeName !== 'standard');

      if (modeName === 'bionic') {
        renderBionicText();
      } else if (modeName === 'standard') {
        renderStandardText();
      }
    };

    // Lazy load libraries client-side on demand
    const loadScript = (url) => {
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = url;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });
    };

    let isJSZipLoaded = false;
    let isPDFJSLoaded = false;
    let isTesseractLoaded = false;

    // Load PDF parser
    const handlePDFUpload = async (file) => {
      const status = document.getElementById('file-status');
      try {
        if (!isPDFJSLoaded) {
          status.textContent = "Downloading PDF parser...";
          await loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
          isPDFJSLoaded = true;
        }

        status.textContent = "Parsing PDF text content...";
        const reader = new FileReader();
        reader.onerror = () => { status.textContent = "Could not read this PDF file."; };
        reader.onload = async (event) => {
          try {
            const typedarray = new Uint8Array(event.target.result);
            const pdf = await pdfjsLib.getDocument(typedarray).promise;
            let fullText = '';
            const maxPages = Math.min(200, pdf.numPages);

            for (let i = 1; i <= maxPages; i++) {
              const page = await pdf.getPage(i);
              const textContent = await page.getTextContent();
              fullText += textContent.items
                .map((item) => `${item.str}${item.hasEOL ? '\n' : ' '}`)
                .join('') + '\n\n';
              document.getElementById('upload-progress-bar').style.width = `${Math.round((i / maxPages) * 100)}%`;
            }

            if (!fullText.trim()) {
              status.textContent = "No selectable text found. Running on-device OCR…";
              const ocrText = await extractPDFWithOCR(pdf, maxPages, status);
              if (ocrText.trim()) {
                status.textContent = `OCR loaded ${maxPages} page${maxPages === 1 ? '' : 's'}.`;
                initReaderSession(ocrText, file.name);
              } else {
                status.textContent = "No text could be read from this PDF.";
              }
              return;
            }

            status.textContent = `Loaded ${maxPages} page${maxPages === 1 ? '' : 's'}.`;
            initReaderSession(fullText, file.name);
          } catch (err) {
            status.textContent = "Could not extract text from this PDF. Try Image OCR for scanned pages.";
            console.error(err);
          }
        };
        reader.readAsArrayBuffer(file);
      } catch (err) {
        status.textContent = "Could not load the PDF parser. Please try again.";
        console.error(err);
      }
    };

    // Load EPUB parser
    const handleEPUBUpload = async (file) => {
      if (!isJSZipLoaded) {
        document.getElementById('file-status').textContent = "Downloading EPUB decompression parser...";
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js');
        isJSZipLoaded = true;
      }

      document.getElementById('file-status').textContent = "Extracting book pages...";
      try {
        const reader = new FileReader();
        reader.onload = async function(e) {
          const zip = await JSZip.loadAsync(e.target.result);
          let htmlFiles = [];
          zip.forEach((path, zFile) => {
            if (path.endsWith('.html') || path.endsWith('.xhtml')) {
              htmlFiles.push(zFile);
            }
          });

          // Order logically
          htmlFiles.sort((a, b) => a.name.localeCompare(b.name, undefined, {numeric: true}));

          let fullText = '';
          for (let i = 0; i < htmlFiles.length; i++) {
            const content = await htmlFiles[i].async('text');
            const parser = new DOMParser();
            const doc = parser.parseFromString(content, 'text/html');
            doc.querySelectorAll('script, style').forEach(el => el.remove());
            fullText += doc.body.innerText + '\n\n';
            
            const percent = Math.round((i / htmlFiles.length) * 100);
            document.getElementById('upload-progress-bar').style.width = percent + '%';
          }

          initReaderSession(fullText, file.name);
        };
        reader.readAsArrayBuffer(file);
      } catch (err) {
        alert("Failed to decompress and parse EPUB book.");
        console.error(err);
      }
    };

    const getOCRWorker = async (status) => {
      if (!isTesseractLoaded) {
        status.textContent = "Downloading OCR engine…";
        await loadScript('https://cdn.jsdelivr.net/npm/tesseract.js@5.0.3/dist/tesseract.min.js');
        isTesseractLoaded = true;
      }
      return Tesseract.createWorker('eng');
    };

    const extractPDFWithOCR = async (pdf, maxPages, status) => {
      const worker = await getOCRWorker(status);
      let text = '';
      try {
        for (let i = 1; i <= maxPages; i++) {
          status.textContent = `Reading scanned page ${i} of ${maxPages}…`;
          const page = await pdf.getPage(i);
          const viewport = page.getViewport({ scale: 2 });
          const canvas = document.createElement('canvas');
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
          const result = await worker.recognize(canvas);
          text += `${result.data.text}\n\n`;
          document.getElementById('upload-progress-bar').style.width = `${Math.round((i / maxPages) * 100)}%`;
        }
      } finally {
        await worker.terminate();
      }
      return text;
    };

    // OCR engine handler
    const handleOCRUpload = async (file) => {
      document.getElementById('ocr-progress').classList.remove('hidden');
      document.getElementById('ocr-progress-bar').style.width = '10%';
      const status = document.getElementById('ocr-status');
      document.getElementById('ocr-progress-bar').style.width = '30%';

      try {
        const worker = await getOCRWorker(status);
        status.textContent = "Extracting text from image locally…";
        document.getElementById('ocr-progress-bar').style.width = '50%';
        const ret = await worker.recognize(file);
        document.getElementById('ocr-progress-bar').style.width = '90%';
        
        const extractedText = ret.data.text;
        await worker.terminate();

        document.getElementById('ocr-progress-bar').style.width = '100%';
        if (extractedText.trim().length === 0) {
          alert("Could not identify any text in this image.");
          document.getElementById('ocr-progress').classList.add('hidden');
          return;
        }

        initReaderSession(extractedText, file.name);
      } catch (err) {
        alert("OCR parsing failed.");
        console.error(err);
        document.getElementById('ocr-progress').classList.add('hidden');
      }
    };

    // Load parsed text into reader session
    const initReaderSession = (text, sourceLabel = 'Document') => {
      if (!text || text.trim().length === 0) {
        alert("No valid text extracted.");
        return;
      }
      
      // Enforce free tier limits: 3000 words limit on uploads
      const tempWords = text.trim().split(/\s+/);
      if (tempWords.length > 3000 && !state.isPremium) {
        const upgrade = confirm(`Your document has ${tempWords.length.toLocaleString()} words. The free tier limits reading to 3,000 words to cover AdSense/hosting costs. Upgrade to Premium Lifetime ($9.00 one-time) to read unlimited length books and unlock a completely ad-free workspace!`);
        if (upgrade) {
          setTimeout(() => {
            const pricing = document.querySelector('.pricing-card');
            if (pricing) {
              pricing.scrollIntoView({ behavior: 'smooth' });
              pricing.style.outline = "3px solid var(--color-primary)";
              pricing.style.outlineOffset = "4px";
              setTimeout(() => {
                pricing.style.outline = "none";
              }, 4000);
            }
          }, 200);
        }
        return;
      }
      
      parseText(text);
      state.sourceLabel = sourceLabel;
      updateDocumentContext();
      
      // Reset reader panels
      const readerScreen = document.getElementById('reader-screen');
      readerScreen.classList.remove('hidden');
      setMode('rsvp');
      renderRSVPWord();

      // Scroll smoothly to the reading card
      readerScreen.scrollIntoView({ behavior: 'smooth' });
    };

    // Clean reader closure
    const closeReaderSession = () => {
      pauseReader();
      document.getElementById('reader-screen').classList.add('hidden');
    };

    const populateVoices = () => {
      if (!window.speechSynthesis) return;
      
      const voiceSelect = document.getElementById('select-voice');
      if (!voiceSelect) return;
      
      // Clear existing options
      voiceSelect.innerHTML = '<option value="">Default System Voice</option>';
      
      let voices = window.speechSynthesis.getVoices();
      
      // Sort voices so neural/natural/online voices come first
      voices.sort((a, b) => {
        const isNeuralA = a.name.includes('Natural') || a.name.includes('Neural') || a.name.includes('Google') || a.name.includes('Online') || a.localService === false;
        const isNeuralB = b.name.includes('Natural') || b.name.includes('Neural') || b.name.includes('Google') || b.name.includes('Online') || b.localService === false;
        if (isNeuralA && !isNeuralB) return -1;
        if (!isNeuralA && isNeuralB) return 1;
        return a.name.localeCompare(b.name);
      });
      
      voices.forEach(voice => {
        const isNeural = voice.name.includes('Natural') || voice.name.includes('Neural') || voice.name.includes('Google') || voice.name.includes('Online') || voice.localService === false;
        const option = document.createElement('option');
        option.value = voice.name;
        option.textContent = isNeural ? `✨ [Neural] ${voice.name} (${voice.lang})` : `${voice.name} (${voice.lang})`;
        voiceSelect.appendChild(option);
      });
    };

    if (window.speechSynthesis) {
      window.speechSynthesis.onvoiceschanged = populateVoices;
    }

    // ---------------- EVENT LIFECYCLES ----------------
    document.addEventListener('DOMContentLoaded', () => {
      loadState();
      populateVoices();

      // Navigation tabs trigger
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
          
          btn.classList.add('active');
          document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
        });
      });

      // Demo button loader
      document.getElementById('btn-demo').addEventListener('click', () => {
        const demo = "Rapid Serial Visual Presentation (RSVP) is a reading technique that flashes words in a single location on the screen. By removing horizontal eye movements, readers can quickly scan literature and dramatically decrease strain. Bionic Reading bold highlights the prefix structure of letters, guiding your focus down lines seamlessly. Synced Audio combines with RSVP to form a multi-channel learning experience, ensuring high focus at faster speeds.";
        const textInput = document.getElementById('text-input');
        textInput.value = demo;
        textInput.dispatchEvent(new Event('input', { bubbles: true }));
      });

      document.getElementById('btn-hero-demo')?.addEventListener('click', () => {
        document.getElementById('btn-demo').click();
        document.getElementById('btn-load-paste').click();
      });

      const previewWords = ['Finish', 'more', 'reading', 'with', 'less', 'friction', 'and', 'keep', 'your', 'focus', 'from', 'first', 'page', 'to', 'final', 'point'];
      let previewIndex = 0;
      let heroPreviewTimer;
      let heroPreviewPlaying = true;
      const heroPlayButton = document.getElementById('hero-play');
      const renderHeroPreview = () => {
        const word = previewWords[previewIndex++ % previewWords.length];
        const orpIndex = getOrpIndex(word);
        document.getElementById('hero-word-left').textContent = word.slice(0, orpIndex);
        document.getElementById('hero-word-orp').textContent = word.charAt(orpIndex);
        document.getElementById('hero-word-right').textContent = word.slice(orpIndex + 1);
        document.querySelector('.hero-word').classList.remove('is-changing');
        requestAnimationFrame(() => document.querySelector('.hero-word').classList.add('is-changing'));
      };
      const updateHeroPlayback = () => {
        clearInterval(heroPreviewTimer);
        heroPlayButton.textContent = heroPreviewPlaying ? 'Ⅱ' : '▶';
        heroPlayButton.setAttribute('aria-pressed', String(heroPreviewPlaying));
        heroPlayButton.setAttribute('aria-label', heroPreviewPlaying ? 'Pause RSVP preview' : 'Play RSVP preview');
        if (heroPreviewPlaying) heroPreviewTimer = setInterval(renderHeroPreview, 60000 / Number(document.getElementById('hero-wpm-slider').value));
      };
      document.getElementById('hero-wpm-slider').addEventListener('input', (event) => {
        document.getElementById('hero-wpm-output').textContent = event.target.value;
        updateHeroPlayback();
      });
      heroPlayButton.addEventListener('click', () => {
        heroPreviewPlaying = !heroPreviewPlaying;
        updateHeroPlayback();
      });
      updateHeroPlayback();

      document.querySelectorAll('[data-open-tab]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          document.querySelector(`.tab-btn[data-tab="${trigger.dataset.openTab}"]`)?.click();
          document.getElementById('importer-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Load pasted text
      document.getElementById('btn-load-paste').addEventListener('click', () => {
        const pasteVal = document.getElementById('text-input').value;
        if (!pasteVal.trim()) {
          alert("Please paste some text to begin.");
          return;
        }
        initReaderSession(pasteVal, 'Pasted text');
      });

      document.getElementById('text-input').addEventListener('input', (event) => {
        const pastedText = event.target.value.trim();
        if (pastedText) {
          parseText(pastedText);
          state.sourceLabel = 'Pasted text';
          updateDocumentContext();
        } else if (state.sourceLabel === 'Pasted text') {
          parseText('');
          state.sourceLabel = '';
          updateDocumentContext();
        }
      });

      // Close button
      document.getElementById('btn-close-reader').addEventListener('click', closeReaderSession);

      // Mode switch
      document.querySelectorAll('.mode-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          setMode(btn.dataset.mode);
        });
      });

      // Playback buttons
      const playBtn = document.getElementById('btn-rsvp-play');
      playBtn.addEventListener('click', () => {
        if (state.isPlaying) {
          pauseReader();
        } else {
          playRSVP();
        }
      });

      document.getElementById('btn-rsvp-prev').addEventListener('click', () => {
        pauseReader();
        state.currentIndex = Math.max(0, state.currentIndex - 2);
        renderRSVPWord();
      });

      document.getElementById('btn-rsvp-next').addEventListener('click', () => {
        pauseReader();
        state.currentIndex = Math.min(state.words.length - 1, state.currentIndex + 2);
        renderRSVPWord();
      });

      // TTS audio toggler
      const ttsBtn = document.getElementById('btn-rsvp-tts');
      ttsBtn.addEventListener('click', () => {
        state.ttsActive = !state.ttsActive;
        ttsBtn.textContent = state.ttsActive ? "Audio Sync: On" : "Audio Sync: Off";
        ttsBtn.classList.toggle('active', state.ttsActive);
        if (state.isPlaying) {
          pauseReader();
          playRSVP();
        }
      });

      // Fullscreen mode toggler
      const fsBtn = document.getElementById('btn-fullscreen');
      fsBtn.addEventListener('click', () => {
        const container = document.querySelector('.rsvp-word-container');
        if (!document.fullscreenElement) {
          container.requestFullscreen().catch(err => {
            alert(`Error transitioning to fullscreen: ${err.message}`);
          });
        } else {
          document.exitFullscreen();
        }
      });

      // WPM Slider handler
      const wpmSlider = document.getElementById('slider-wpm');
      wpmSlider.addEventListener('input', (e) => {
        state.wpm = parseInt(e.target.value);
        document.getElementById('wpm-display').textContent = state.wpm;
        localStorage.setItem('wpm', state.wpm.toString());
        if (state.isPlaying && state.ttsActive) {
          // Restart speech to adjust pitch/rate changes
          pauseReader();
          playRSVP();
        }
      });

      // Voice Selector handler
      document.getElementById('select-voice').addEventListener('change', () => {
        if (state.isPlaying && state.ttsActive) {
          pauseReader();
          playRSVP();
        }
      });

      // Pitch Slider handler
      const pitchSlider = document.getElementById('slider-pitch');
      pitchSlider.addEventListener('input', (e) => {
        const pitch = parseFloat(e.target.value);
        document.getElementById('pitch-display').textContent = pitch.toFixed(1);
        if (state.isPlaying && state.ttsActive) {
          pauseReader();
          playRSVP();
        }
      });

      // Find and Replace Action
      document.getElementById('btn-run-replace').addEventListener('click', () => {
        const findVal = document.getElementById('input-find').value.trim();
        const replaceVal = document.getElementById('input-replace').value;
        if (!findVal) return alert("Please enter text to find.");
        
        const textarea = document.getElementById('text-input');
        const originalText = textarea.value;
        // Escape regex special characters for safety literal replacement
        const escapedFind = findVal.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
        const regex = new RegExp(escapedFind, 'g');
        const cleanText = originalText.replace(regex, replaceVal);
        
        textarea.value = cleanText;
        alert(`Replaced all occurrences of "${findVal}" with "${replaceVal}"!`);
      });

      // Font slider handler
      const sizeSlider = document.getElementById('slider-font-size');
      sizeSlider.addEventListener('input', (e) => {
        state.fontSize = parseInt(e.target.value);
        document.getElementById('font-size-display').textContent = state.fontSize;
        document.querySelectorAll('.rsvp-word-container, .standard-reader-view').forEach((view) => {
          view.style.fontSize = state.fontSize / 6 + 'rem';
        });
        localStorage.setItem('fontSize', state.fontSize.toString());
      });

      // Font Family Selector
      const fontSelect = document.getElementById('select-font');
      fontSelect.addEventListener('change', (e) => {
        state.font = e.target.value;
        document.documentElement.setAttribute('data-font', state.font);
        localStorage.setItem('font', state.font);
      });

      // Theme badge selectors
      document.querySelectorAll('.theme-badge').forEach(badge => {
        badge.addEventListener('click', () => {
          state.theme = badge.dataset.theme;
          document.documentElement.setAttribute('data-theme', state.theme);
          localStorage.setItem('theme', state.theme);
        });
      });

      // Reading Position slider
      const progressSlider = document.getElementById('slider-progress');
      progressSlider.addEventListener('input', (e) => {
        pauseReader();
        const percent = parseInt(e.target.value);
        state.currentIndex = Math.round((percent / 100) * (state.words.length - 1));
        renderRSVPWord();
      });

      // File drag-and-drop detection
      const dropzone = document.getElementById('file-dropzone');
      dropzone.addEventListener('click', () => document.getElementById('file-input').click());
      
      const fileInput = document.getElementById('file-input');
      fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
          document.getElementById('file-progress').classList.remove('hidden');
          const filename = file.name.toLowerCase();
          if (filename.endsWith('.pdf')) {
            handlePDFUpload(file);
          } else if (filename.endsWith('.epub')) {
            handleEPUBUpload(file);
          } else {
            // Text file
            const reader = new FileReader();
            reader.onload = (event) => initReaderSession(event.target.result, file.name);
            reader.readAsText(file);
          }
        }
      });

      // Image OCR Drag and drop
      const ocrZone = document.getElementById('ocr-dropzone');
      ocrZone.addEventListener('click', () => document.getElementById('ocr-input').click());
      
      const ocrInput = document.getElementById('ocr-input');
      ocrInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) handleOCRUpload(file);
      });

      // URL parser text loader
      document.getElementById('btn-load-url').addEventListener('click', async () => {
        const url = document.getElementById('url-input').value;
        if (!url) return alert("Please enter a valid URL.");
        
        document.getElementById('btn-load-url').textContent = "Extracting...";
        try {
          // First-party server-side fetch — no third-party CORS proxy dependency
          const response = await fetch(`/api/extract?url=${encodeURIComponent(url)}`);
          if (!response.ok) throw new Error("Server-side extraction failed.");
          const json = await response.json();
          
          const parser = new DOMParser();
          const doc = parser.parseFromString(json.contents, 'text/html');
          
          // Remove noise script markup
          doc.querySelectorAll('script, style, nav, footer, header, form').forEach(el => el.remove());
          
          const title = doc.querySelector('h1')?.innerText || "Web Article";
          const paragraphs = Array.from(doc.querySelectorAll('p, h2, h3'))
            .map(p => p.innerText.trim())
            .filter(t => t.length > 30) // Filter layout words
            .join('\n\n');

          document.getElementById('btn-load-url').textContent = "Extract Text";
          if (paragraphs.length < 100) {
            alert("Could not extract clean body content. Copy pasting is recommended.");
            return;
          }
          initReaderSession(`${title}\n\n${paragraphs}`, title);
        } catch (err) {
          alert("Failed to load webpage content.");
          document.getElementById('btn-load-url').textContent = "Extract Text";
          console.error(err);
        }
      });

      // Gemini: device session only (not raw license key)
      const getPremiumToken = () => getDeviceSession();
      const isPremium = () => state.isPremium && !!getDeviceSession();

      document.getElementById('btn-save-key').addEventListener('click', () => {
        const key = document.getElementById('ai-key').value;
        if (key) {
          localStorage.setItem('gemini_key', key);
          alert("Gemini key saved locally!");
        }
      });
      
      const getGeminiKey = () => localStorage.getItem('gemini_key') || "";
      document.getElementById('ai-key').value = getGeminiKey();

      async function getGeminiModels(key) {
        const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models?key=${key}`);
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data?.error?.message || `Unable to list Gemini models (${res.status})`);
        const available = new Set((data.models || []).filter((model) => model.supportedGenerationMethods?.includes('generateContent')).map((model) => model.name.replace('models/', '')));
        const preferred = ['gemini-3.5-flash', 'gemini-3-flash-preview', 'gemini-2.5-flash-lite', 'gemini-2.5-flash'];
        const models = [...preferred.filter((name) => available.has(name)), ...[...available].filter((name) => name.startsWith('gemini') && !preferred.includes(name))];
        if (!models.length) throw new Error('This API key has no supported Gemini text model. Enable Gemini API access in Google AI Studio.');
        return models;
      }

      async function callGemini(bodyPayload) {
        if (isPremium() && getPremiumToken()) {
          const res = await fetch('/api/gemini', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${getPremiumToken()}`,
            },
            body: JSON.stringify(bodyPayload),
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.error || 'Premium AI proxy failed');
          }
          return res.json();
        }
        const key = getGeminiKey();
        if (!key) throw new Error('NO_KEY');
        const models = await getGeminiModels(key);
        let lastError;
        for (const model of models) {
          const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${key}`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(bodyPayload),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok) return data;
          lastError = data?.error?.message || `Gemini request failed (${res.status})`;
          if (res.status !== 404) break;
        }
        throw new Error(lastError);
      }

      // Helper to ensure text is loaded before running AI operations
      const ensureTextLoaded = () => {
        if (!state.text || state.text.trim() === '') {
          const pasteVal = document.getElementById('text-input').value;
          if (pasteVal.trim()) {
            parseText(pasteVal);
            state.sourceLabel = 'Pasted text';
            updateDocumentContext();
            return true;
          }
          alert("Please paste text or upload a file first!");
          return false;
        }
        return true;
      };

      document.getElementById('btn-ai-summary').addEventListener('click', async () => {
        if (!ensureTextLoaded()) return;
        if (!isPremium() && !getGeminiKey()) return alert("Please enter and save your Gemini API Key first, or upgrade to Premium.");
        
        const summaryBtn = document.getElementById('btn-ai-summary');
        summaryBtn.textContent = "Summarizing...";
        
        try {
          // Slice top content to stay within standard limits
          const textChunk = state.text.slice(0, 8000);
          const data = await callGemini({
            contents: [{
              parts: [{ text: `Generate a concise speed-reading summary with bullet points for this text:\n\n${textChunk}` }]
            }]
          });
          
          const summaryText = data.candidates?.[0]?.content?.parts?.[0]?.text;
          if (!summaryText) throw new Error('Gemini returned no summary text.');
          
          document.getElementById('ai-response-box').classList.remove('hidden');
          document.getElementById('ai-response-title').textContent = "AI summary";
          document.getElementById('ai-summary-view').classList.remove('hidden');
          document.getElementById('ai-chat-view').classList.add('hidden');
          document.getElementById('ai-response-text').innerText = summaryText;
          summaryBtn.textContent = "Generate summary";
        } catch (err) {
          if (err.message === 'NO_KEY') return alert("Please enter and save your Gemini API Key first, or upgrade to Premium.");
          alert(`AI Summarization failed: ${err.message}`);
          summaryBtn.textContent = "Generate summary";
          console.error(err);
        }
      });

      document.getElementById('btn-ai-chat').addEventListener('click', () => {
        if (!ensureTextLoaded()) return;
        if (!isPremium() && !getGeminiKey()) {
          return alert("Please enter and save your Gemini API Key first, or upgrade to Premium.");
        }
        
        document.getElementById('ai-response-box').classList.remove('hidden');
        document.getElementById('ai-response-title').textContent = "Chat with document";
        document.getElementById('ai-summary-view').classList.add('hidden');
        document.getElementById('ai-chat-view').classList.remove('hidden');
        
        const chatHistory = document.getElementById('chat-history');
        chatHistory.innerHTML = `<div class="chat-message assistant">I've parsed your document (${state.words.length} words). Ask me any questions, and I will extract the answers for you!</div>`;
        chatHistory.scrollTop = chatHistory.scrollHeight;
      });

      document.getElementById('btn-send-chat').addEventListener('click', async () => {
        if (!isPremium() && !getGeminiKey()) return alert("Please enter and save your Gemini API Key first, or upgrade to Premium.");
        
        const inputEl = document.getElementById('chat-user-input');
        const query = inputEl.value.trim();
        if (!query) return;
        
        inputEl.value = '';
        
        const chatHistory = document.getElementById('chat-history');
        // Escape HTML to prevent basic XSS
        const escapeHtml = (str) => str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
        
        chatHistory.innerHTML += `<div class="chat-message user">${escapeHtml(query)}</div>`;
        chatHistory.scrollTop = chatHistory.scrollHeight;
        
        const loadingId = 'chat-loading-' + Date.now();
        chatHistory.innerHTML += `<div class="chat-message assistant" id="${loadingId}">Typing...</div>`;
        chatHistory.scrollTop = chatHistory.scrollHeight;
        
        try {
          const docTextSlice = state.text.slice(0, 15000);
          const data = await callGemini({
            contents: [{
              parts: [{ 
                text: `You are an AI speed reading assistant. The user has loaded this document in their reader:\n\n---\n${docTextSlice}\n---\n\nAnswer the user's question accurately based on the document text. Keep your answer clear and concise (under 3-4 sentences).\n\nUser Question: ${query}`
              }]
            }]
          });
          
          const reply = data.candidates?.[0]?.content?.parts?.[0]?.text;
          if (!reply) throw new Error('Gemini returned no chat response.');
          
          const loadingEl = document.getElementById(loadingId);
          if (loadingEl) loadingEl.remove();
          
          chatHistory.innerHTML += `<div class="chat-message assistant">${escapeHtml(reply)}</div>`;
          chatHistory.scrollTop = chatHistory.scrollHeight;
        } catch (err) {
          const loadingEl = document.getElementById(loadingId);
          if (loadingEl) loadingEl.remove();
          
          chatHistory.innerHTML += `<div class="chat-message assistant error">${escapeHtml(`Gemini failed: ${err.message}`)}</div>`;
          chatHistory.scrollTop = chatHistory.scrollHeight;
          console.error(err);
        }
      });

      document.getElementById('chat-user-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          document.getElementById('btn-send-chat').click();
        }
      });

      document.getElementById('btn-close-ai-box').addEventListener('click', () => {
        document.getElementById('ai-response-box').classList.add('hidden');
      });

      // Keyboard navigation rules
      document.addEventListener('keydown', (e) => {
        // Skip shortcuts if writing in text inputs
        if (document.activeElement.tagName === 'TEXTAREA' || document.activeElement.tagName === 'INPUT') {
          return;
        }

        // Spacebar play-pause toggle
        if (e.code === 'Space') {
          e.preventDefault();
          if (state.isPlaying) pauseReader();
          else playRSVP();
        }
        
        // Escape Close Reader
        if (e.code === 'Escape' && !document.getElementById('reader-screen').classList.contains('hidden')) {
          closeReaderSession();
        }

        // Speeds Adjusters (ArrowUp/Down)
        if (e.code === 'ArrowUp') {
          e.preventDefault();
          state.wpm = Math.min(1000, state.wpm + 50);
          document.getElementById('slider-wpm').value = state.wpm;
          document.getElementById('wpm-display').textContent = state.wpm;
          localStorage.setItem('wpm', state.wpm.toString());
        }
        if (e.code === 'ArrowDown') {
          e.preventDefault();
          state.wpm = Math.max(100, state.wpm - 50);
          document.getElementById('slider-wpm').value = state.wpm;
          document.getElementById('wpm-display').textContent = state.wpm;
          localStorage.setItem('wpm', state.wpm.toString());
        }

        // Timeline jumps (ArrowLeft/Right)
        if (e.code === 'ArrowLeft') {
          pauseReader();
          state.currentIndex = Math.max(0, state.currentIndex - 5);
          renderRSVPWord();
        }
        if (e.code === 'ArrowRight') {
          pauseReader();
          state.currentIndex = Math.min(state.words.length - 1, state.currentIndex + 5);
          renderRSVPWord();
        }

        // Theme shortcuts cycle: D key
        if (e.key.toLowerCase() === 'd') {
          const themes = ['light', 'sepia', 'dark', 'amoled'];
          let currentIdx = themes.indexOf(state.theme);
          let nextIdx = (currentIdx + 1) % themes.length;
          state.theme = themes[nextIdx];
          document.documentElement.setAttribute('data-theme', state.theme);
          localStorage.setItem('theme', state.theme);
        }
      });

      // Canvas share card generation
      document.getElementById('btn-share-stats').addEventListener('click', () => {
        const stats = {
          wordsRead: state.stats.wordsRead,
          speed: state.wpm,
          timeSaved: Math.round(Math.max(0, (state.stats.wordsRead / 200) - state.stats.timeSpent))
        };
        
        const canvas = document.createElement('canvas');
        canvas.width = 800;
        canvas.height = 400;
        const ctx = canvas.getContext('2d');

        // Dark gradient background matching AMOLED Black
        const grad = ctx.createLinearGradient(0, 0, 800, 400);
        grad.addColorStop(0, '#000000');
        grad.addColorStop(0.5, '#0f172a');
        grad.addColorStop(1, '#1e293b');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, 800, 400);

        // Grid accents
        ctx.strokeStyle = 'rgba(255,255,255,0.03)';
        ctx.lineWidth = 2;
        for (let i = 0; i < 800; i += 40) {
          ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, 400); ctx.stroke();
        }
        for (let j = 0; j < 400; j += 40) {
          ctx.beginPath(); ctx.moveTo(0, j); ctx.lineTo(800, j); ctx.stroke();
        }

        // Accent glowing border lines
        ctx.strokeStyle = '#2563eb';
        ctx.lineWidth = 6;
        ctx.strokeRect(0, 0, 800, 400);

        // Header Title
        ctx.fillStyle = '#ffffff';
        ctx.font = '800 40px system-ui, -apple-system, sans-serif';
        ctx.fillText('⚡ SpeedRead Milestone', 60, 90);

        // Dividers
        ctx.fillStyle = '#ef4444';
        ctx.fillRect(60, 115, 200, 5);

        // Main Stat content
        ctx.fillStyle = '#cbd5e1';
        ctx.font = '600 24px system-ui, -apple-system, sans-serif';
        ctx.fillText(`Total Words Speed-Read:`, 60, 180);
        
        ctx.fillStyle = '#3b82f6';
        ctx.font = '800 44px system-ui, sans-serif';
        ctx.fillText(`${stats.wordsRead.toLocaleString()}`, 60, 230);

        ctx.fillStyle = '#cbd5e1';
        ctx.font = '600 24px system-ui, sans-serif';
        ctx.fillText(`Current Speed: ${stats.speed} WPM`, 450, 180);
        ctx.fillText(`Est. Reading Time Saved: ${stats.timeSaved} mins`, 450, 230);

        // Sub Brand slogan
        ctx.fillStyle = '#94a3b8';
        ctx.font = '500 18px system-ui, sans-serif';
        ctx.fillText(`Read faster with RSVP, bionic reading and TTS. ${location.hostname}`, 60, 340);

        // Output canvas image into preview image element
        document.getElementById('share-card-img').src = canvas.toDataURL('image/png');
        document.getElementById('share-modal').classList.remove('hidden');
      });

      document.getElementById('btn-close-modal').addEventListener('click', () => {
        document.getElementById('share-modal').classList.add('hidden');
      });
      
      // Dodo Payments checkout
      document.getElementById('btn-buy-premium').addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        btn.disabled = true;
        btn.textContent = 'Redirecting to checkout...';
        try {
          const res = await fetch('/api/create-checkout', { method: 'POST' });
          const data = await res.json();
          if (!data.checkout_url) throw new Error(data.error || 'No checkout URL returned');
          window.location.href = data.checkout_url;
        } catch (err) {
          alert('Could not start checkout. Please try again shortly.');
          console.error(err);
          btn.disabled = false;
          btn.textContent = 'Get Lifetime Pro — $9';
        }
      });

      const activateOnThisDevice = async (licenseKey, revokeDeviceId) => {
        const status = document.getElementById('license-status');
        const body = {
          license_key: licenseKey,
          device_id: getDeviceId(),
          device_label: getDeviceLabel(),
        };
        if (revokeDeviceId) body.revoke_device_id = revokeDeviceId;

        const res = await fetch('/api/activate-license', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();

        if (data.code === 'DEVICE_LIMIT' && data.devices) {
          renderDeviceList(data.devices, data.max_devices || 5);
          status.textContent = data.error + ' Click Revoke on a device below, then Activate again.';
          localStorage.setItem('license_key', licenseKey);
          if (document.getElementById('license-key-display')) {
            document.getElementById('license-key-display').value = licenseKey;
            document.getElementById('license-display').classList.remove('hidden');
          }
          return data;
        }

        if (!res.ok || !data.ok) {
          status.textContent = data.error || 'Invalid license key.';
          return data;
        }

        unlockPremium({
          licenseKey: data.license_key || licenseKey,
          sessionToken: data.token,
          devices: data.devices,
          maxDevices: data.max_devices,
        });
        status.textContent = 'Premium unlocked on this device (slot secured).';
        return data;
      };

      document.getElementById('btn-activate-license').addEventListener('click', async () => {
        const input = document.getElementById('license-key-input');
        const status = document.getElementById('license-status');
        const licenseKey = (input.value || getStoredLicenseKey() || '').trim();
        if (!licenseKey) {
          status.textContent = 'Paste your license key first.';
          return;
        }
        status.textContent = 'Binding this device…';
        try {
          await activateOnThisDevice(licenseKey);
          input.value = '';
        } catch (err) {
          console.error(err);
          status.textContent = 'Activation failed. Check your connection and try again.';
        }
      });

      document.getElementById('device-list').addEventListener('click', async (e) => {
        const btn = e.target.closest('.btn-revoke-device');
        if (!btn) return;
        const revokeId = btn.getAttribute('data-device-id');
        const license = getStoredLicenseKey() || document.getElementById('license-key-input').value.trim();
        if (!license || !revokeId) return;
        const status = document.getElementById('license-status');
        status.textContent = 'Revoking device…';
        try {
          await activateOnThisDevice(license, revokeId);
          status.textContent = 'Device revoked. This device is now activated.';
        } catch (err) {
          console.error(err);
          status.textContent = 'Could not revoke device.';
        }
      });

      document.getElementById('btn-copy-license').addEventListener('click', async () => {
        const val = document.getElementById('license-key-display').value;
        if (!val) return;
        try {
          await navigator.clipboard.writeText(val);
          document.getElementById('license-status').textContent = 'License key copied — store it offline, do not share publicly.';
        } catch {
          document.getElementById('license-key-display').select();
          document.execCommand('copy');
          document.getElementById('license-status').textContent = 'License key selected — copy manually if needed.';
        }
      });

      // Return from Dodo checkout → license + bind this device
      const returnParams = new URLSearchParams(window.location.search);
      if (returnParams.get('checkout') === 'return' && returnParams.get('payment_id')) {
        const paymentId = returnParams.get('payment_id');
        const qs = new URLSearchParams({
          payment_id: paymentId,
          device_id: getDeviceId(),
          device_label: getDeviceLabel(),
        });
        fetch(`/api/verify-payment?${qs}`)
          .then(r => r.json())
          .then((data) => {
            history.replaceState(null, '', window.location.pathname);
            if (data.ok) {
              unlockPremium({
                licenseKey: data.license_key,
                sessionToken: data.token,
                devices: data.devices,
                maxDevices: data.max_devices,
              });
              if (!data.token) {
                alert(data.warning || 'Payment confirmed. Save your license key, then click Activate device if Premium is not active yet.');
              } else {
                alert('Payment confirmed! Premium is active on this device. Save your license key offline for other devices (max 5).');
              }
              const panel = document.getElementById('license-panel');
              if (panel) panel.scrollIntoView({ behavior: 'smooth' });
            } else {
              alert('We could not confirm this payment. If you were charged, contact support with your receipt.');
            }
          })
          .catch(() => history.replaceState(null, '', window.location.pathname));
      }

      // Chrome extension handoff (content-handoff.js + retries / custom event)
      const applyExtensionPremium = () => {
        if (localStorage.getItem('premium_token')) {
          localStorage.setItem('is_premium', 'true');
          state.isPremium = true;
          applyPremiumUI();
          return true;
        }
        return false;
      };

      const loadExtensionHandoff = () => {
        try {
          const raw = sessionStorage.getItem('sr_extension_article');
          if (!raw) return false;
          sessionStorage.removeItem('sr_extension_article');
          const data = JSON.parse(raw);
          const title = (data.title || '').trim();
          const text = (data.text || '').trim();
          applyExtensionPremium();
          if (!text || text.length < 40) {
            // URL-only handoff: fall through to ?url=
            if (data.url) {
              const urlInput = document.getElementById('url-input');
              if (urlInput) {
                urlInput.value = data.url;
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                document.querySelector('.tab-btn[data-tab="url"]')?.classList.add('active');
                document.getElementById('tab-url')?.classList.add('active');
                document.getElementById('btn-load-url')?.click();
                return true;
              }
            }
            return false;
          }
          const combined = title ? `${title}\n\n${text}` : text;
          history.replaceState(null, '', window.location.pathname);
          initReaderSession(combined, title || 'Chrome extension article');
          return true;
        } catch (e) {
          console.warn('Extension handoff failed', e);
          return false;
        }
      };

      const runExtensionBoot = () => {
        if (loadExtensionHandoff()) return;
        const autoUrl = returnParams.get('url');
        if (autoUrl) {
          const urlInput = document.getElementById('url-input');
          if (urlInput) {
            urlInput.value = autoUrl;
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelector('.tab-btn[data-tab="url"]')?.classList.add('active');
            document.getElementById('tab-url')?.classList.add('active');
            history.replaceState(null, '', window.location.pathname + window.location.hash);
            document.getElementById('btn-load-url')?.click();
          }
        }
        if (returnParams.get('source') === 'extension' || sessionStorage.getItem('sr_from_extension')) {
          sessionStorage.removeItem('sr_from_extension');
          applyExtensionPremium();
        }
      };

      runExtensionBoot();
      // Late handoff if content script wins the race after DOMContentLoaded
      window.addEventListener('sr-extension-handoff', () => {
        applyExtensionPremium();
        loadExtensionHandoff();
      });
      setTimeout(runExtensionBoot, 250);
    });
  </script>

