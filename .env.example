# ─── Public (safe to expose in browser / Astro build) ───
# Domain is set in astro.config.mjs (site: https://speedread-web.com)

# Google Analytics 4 — from analytics.google.com → Data Stream → Measurement ID
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense — from ads.google.com (ca-pub-…)
PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Optional manual ad units (create in AdSense → Ads → By ad unit)
PUBLIC_ADSENSE_SLOT_TOP=
PUBLIC_ADSENSE_SLOT_MID=
PUBLIC_ADSENSE_SLOT_BOTTOM=

# Auto ads (recommended for new sites). true/false
PUBLIC_ADSENSE_AUTO_ADS=true

# Show dashed placeholders in production when slots missing (default: only in dev)
# PUBLIC_ADSENSE_SHOW_PLACEHOLDERS=true

# AdSense site verification meta content (Sites → Verify ownership)
# PUBLIC_ADSENSE_VERIFICATION=

# ads.txt publisher id (must match AdSense account). Update public/ads.txt too.
# Format: google.com, pub-XXXXXXXXXXXXXXXX, DIRECT, f08c47fec0942fa0

# ─── Cloudflare Pages secrets (Dashboard → Settings → Environment variables) ───
# DODO_API_KEY=
# DODO_PRODUCT_ID=
# DODO_MODE=test
# DODO_WEBHOOK_SECRET=
# JWT_SECRET=generate-a-long-random-string
# GEMINI_API_KEY=
# LICENSES = Cloudflare KV binding (not an env var — bind in Pages dashboard)
