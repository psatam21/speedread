{
  "manifest_version": 3,
  "name": "SpeedRead Sync",
  "version": "1.0",
  "description": "Send any webpage article text directly to SpeedRead with a single click.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
